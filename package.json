{
  "name": "website.io",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "lighthouse": "lhci autorun",
    "prepare": "husky",
    "images:watch": "node scripts/process-images.js --watch",
    "images:process": "node scripts/process-images.js",
    "blog:hero": "node scripts/generate-blog-hero.js",
    "blog:hero:missing": "node scripts/generate-blog-hero.js --missing"
  },
  "lint-staged": {
    "*.{js,ts,astro}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.14",
    "@astrojs/sitemap": "^3.6.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^5.16.6",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@google/genai": "^1.38.0",
    "@google/generative-ai": "^0.24.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.57.0",
    "@typescript-eslint/parser": "^8.51.0",
    "chokidar": "^5.0.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.34.5"
  }
}
