---
import { ClientRouter } from 'astro:transitions';
import '@fontsource-variable/inter';
import '../styles/global.css';
import NoiseOverlay from '../components/NoiseOverlay.astro';
import BlobBackground from '../components/BlobBackground.astro';
import CookieBanner from '../components/CookieBanner.astro';
import ScrollProgress from '../components/ScrollProgress.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Black Hole Consulting | Architecte Solutions Digitales - France',
  description = "Du site vitrine à l'infrastructure cloud, je conçois et développe des applications performantes et évolutives. Expert indépendant, 17+ ans d'expérience. France entière & remote.",
  canonical = 'https://blackholeconsulting.io/',
} = Astro.props;

// LocalBusiness schema
const localBusinessData = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://blackholeconsulting.io/#localbusiness',
  name: 'Black Hole Consulting',
  image: 'https://blackholeconsulting.io/og-image.png',
  telephone: '+33602180413',
  email: 'cedric@blkhole.fr',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '18 Résidence des Noues',
    addressLocality: 'Montcourt-Fromonville',
    postalCode: '77140',
    addressCountry: 'FR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 48.3056,
    longitude: 2.7038,
  },
  url: 'https://blackholeconsulting.io',
  priceRange: '€€€',
};

// ProfessionalService schema with enriched services
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': 'https://blackholeconsulting.io/#professionalservice',
  name: 'Black Hole Consulting',
  description:
    "Du site vitrine à l'infrastructure cloud, je conçois et développe des applications performantes et évolutives. Expert indépendant, 17+ ans d'expérience.",
  url: 'https://blackholeconsulting.io',
  logo: 'https://blackholeconsulting.io/logo.svg',
  image: 'https://blackholeconsulting.io/og-image.png',
  telephone: '+33602180413',
  email: 'cedric@blkhole.fr',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '18 Résidence des Noues',
    postalCode: '77140',
    addressLocality: 'Montcourt-Fromonville',
    addressRegion: 'Île-de-France',
    addressCountry: 'FR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 48.3056,
    longitude: 2.7038,
  },
  areaServed: {
    '@type': 'Country',
    name: 'France',
  },
  founder: {
    '@type': 'Person',
    name: 'Cédric',
    jobTitle: 'Solution Architect & AI Expert',
  },
  knowsAbout: [
    'Solution Architecture',
    'Artificial Intelligence',
    'Generative AI',
    'Large Language Models',
    'Cloud Computing',
    'AWS',
    'Web Development',
    'DevOps',
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Services',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          '@id': 'https://blackholeconsulting.io/#service-architecture',
          name: 'Architecture de Solutions',
          description: "Conception d'architectures techniques évolutives",
          provider: {
            '@id': 'https://blackholeconsulting.io/#localbusiness',
          },
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          '@id': 'https://blackholeconsulting.io/#service-genai',
          name: 'Intelligence Artificielle & GenAI',
          description: 'Intégration de solutions IA génératives',
          provider: {
            '@id': 'https://blackholeconsulting.io/#localbusiness',
          },
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          '@id': 'https://blackholeconsulting.io/#service-cloud',
          name: 'Cloud & DevOps',
          description: 'Architecture cloud-native et CI/CD',
          provider: {
            '@id': 'https://blackholeconsulting.io/#localbusiness',
          },
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          '@id': 'https://blackholeconsulting.io/#service-web',
          name: 'Développement Web',
          description: 'Applications web modernes sur mesure',
          provider: {
            '@id': 'https://blackholeconsulting.io/#localbusiness',
          },
        },
      },
    ],
  },
  sameAs: ['https://www.linkedin.com/in/cedric-jacqueline-tech'],
