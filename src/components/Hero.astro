---

---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Gradient mesh animated background -->
  <div class="gradient-mesh"></div>

  <!-- Hero glow effect -->
  <div class="hero-glow"></div>

  <!-- Black Hole Singularity Effect -->
  <div class="black-hole" aria-hidden="true">
    <div class="black-hole-core"></div>
    <div class="black-hole-ring"></div>
    <div class="black-hole-ring black-hole-ring-2"></div>
    <div class="black-hole-ring black-hole-ring-3"></div>
    <div class="accretion-disk"></div>
  </div>

  <!-- Animated background shapes (blobs) -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="blob blob-primary w-[500px] h-[500px] top-1/4 left-1/4"></div>
    <div class="blob blob-secondary w-[400px] h-[400px] bottom-1/4 right-1/4"></div>
  </div>

  <div class="container mx-auto px-6 pt-32 pb-20 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Badge (appears first) -->
      <div
        class="fade-in inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--color-bg-secondary)] border border-[var(--color-border)] mb-8"
      >
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        <span class="text-sm text-[var(--color-text-secondary)]"
          >Disponible pour de nouvelles missions</span
        >
      </div>

      <!-- Headline with word-by-word reveal -->
      <h1
        class="word-stagger fade-in stagger-1 text-hero font-bold text-[var(--color-text-primary)] mb-6"
      >
        <span class="word">Architecte</span>
        <span class="word">de</span>
        <span class="word">vos</span>
        <span class="word gradient-text-animated">solutions</span>
        <span class="word gradient-text-animated">digitales</span>
      </h1>

      <!-- Subtitle (appears after headline) -->
      <p
        class="fade-in stagger-3 text-lg md:text-xl text-[var(--color-text-secondary)] max-w-2xl mx-auto mb-10 leading-relaxed"
      >
        J'accompagne startups et scale-ups dans la conception d'applications robustes qui tiennent
        la charge. De l'architecture au déploiement, <strong
          class="text-[var(--color-text-primary)]">17+ ans d'expérience</strong
        > à votre service.
      </p>

      <!-- CTAs (appear last) -->
      <div class="fade-in stagger-4 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#contact" class="btn btn-gradient-animated">
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
            ></path>
          </svg>
          Discuter de votre projet
        </a>
        <a href="#services" class="btn btn-secondary">
          Découvrir mes services
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"
            ></path>
          </svg>
        </a>
      </div>

      <!-- Trust indicators -->
      <div class="fade-in stagger-5 mt-16 pt-10 border-t border-[var(--color-border)]">
        <p class="text-sm text-[var(--color-text-muted)] mb-6">Technologies maîtrisées</p>
        <div
          class="flex flex-wrap items-center justify-center gap-6 md:gap-10 text-[var(--color-text-muted)]"
        >
          <span class="flex items-center gap-2 text-sm">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M13.5 2c-5.288 0-9.649 3.914-10.377 9h-3.123l4 5.917 4-5.917h-2.847c.711-3.972 4.174-7 8.347-7 4.687 0 8.5 3.813 8.5 8.5s-3.813 8.5-8.5 8.5c-3.015 0-5.662-1.583-7.171-3.957l-1.2 1.775c1.916 2.536 4.948 4.182 8.371 4.182 5.799 0 10.5-4.701 10.5-10.5s-4.701-10.5-10.5-10.5z"
              ></path>
            </svg>
            AWS
          </span>
          <span class="flex items-center gap-2 text-sm">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M22.2819 9.8211a5.9847 5.9847 0 0 0-.5157-4.9108 6.0462 6.0462 0 0 0-6.5098-2.9A6.0651 6.0651 0 0 0 4.9807 4.1818a5.9847 5.9847 0 0 0-3.9977 2.9 6.0462 6.0462 0 0 0 .7427 7.0966 5.98 5.98 0 0 0 .511 4.9107 6.051 6.051 0 0 0 6.5146 2.9001A5.9847 5.9847 0 0 0 13.2599 24a6.0557 6.0557 0 0 0 5.7718-4.2058 5.9894 5.9894 0 0 0 3.9977-2.9001 6.0557 6.0557 0 0 0-.7475-7.0729zm-9.022 12.6081a4.4755 4.4755 0 0 1-2.8764-1.0408l.1419-.0804 4.7783-2.7582a.7948.7948 0 0 0 .3927-.6813v-6.7369l2.02 1.1686a.071.071 0 0 1 .038.052v5.5826a4.504 4.504 0 0 1-4.4945 4.4944zm-9.6607-4.1254a4.4708 4.4708 0 0 1-.5346-3.0137l.142.0852 4.783 2.7582a.7712.7712 0 0 0 .7806 0l5.8428-3.3685v2.3324a.0804.0804 0 0 1-.0332.0615L9.74 19.9502a4.4992 4.4992 0 0 1-6.1408-1.6464zM2.3408 7.8956a4.485 4.485 0 0 1 2.3655-1.9728V11.6a.7664.7664 0 0 0 .3879.6765l5.8144 3.3543-2.0201 1.1685a.0757.0757 0 0 1-.071 0l-4.8303-2.7865A4.504 4.504 0 0 1 2.3408 7.872zm16.5963 3.8558L13.1038 8.364 15.1192 7.2a.0757.0757 0 0 1 .071 0l4.8303 2.7913a4.4944 4.4944 0 0 1-.6765 8.1042v-5.6772a.79.79 0 0 0-.4066-.6898zm2.0107-3.0231l-.142-.0852-4.7735-2.7818a.7759.7759 0 0 0-.7854 0L9.409 9.2297V6.8974a.0662.0662 0 0 1 .0284-.0615l4.8303-2.7866a4.4992 4.4992 0 0 1 6.6802 4.66zM8.3065 12.863l-2.02-1.1638a.0804.0804 0 0 1-.038-.0567V6.0742a4.4992 4.4992 0 0 1 7.3757-3.4537l-.142.0805L8.704 5.459a.7948.7948 0 0 0-.3927.6813zm1.0976-2.3654l2.602-1.4998 2.6069 1.4998v2.9994l-2.5974 1.4997-2.6067-1.4997Z"
              ></path>
            </svg>
