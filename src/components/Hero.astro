              ></path>
            </svg>
            Next.js
          </span>
          <span class="flex items-center gap-2 text-sm">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M0 12C0 5.373 5.373 0 12 0s12 5.373 12 12-5.373 12-12 12S0 18.627 0 12zm12.031-6.413c-1.458 0-2.545.614-2.545 1.674 0 1.169.988 1.514 2.22 1.674 1.458.183 1.57.457 1.57.862 0 .549-.571.862-1.683.862-1.314 0-1.885-.343-2.108-.988-.046-.137-.16-.228-.297-.228h-.891c-.183 0-.32.137-.32.297 0 .8.834 1.766 3.02 1.766 1.803 0 2.888-.731 2.888-1.994 0-1.17-.8-1.492-2.48-1.766-1.691-.251-1.691-.411-1.691-.731 0-.549.502-.731 1.337-.731 1.085 0 1.554.274 1.714.845.046.137.16.228.297.228h.891c.183 0 .32-.137.32-.297 0-.731-.685-1.658-2.822-1.658zm-6.537.183c-.16 0-.297.137-.297.297v3.77c0 .137.046.274.137.365l2.651 2.651a.288.288 0 0 0 .411 0l.16-.16a.288.288 0 0 0 0-.411l-2.468-2.468V6.267c0-.16-.137-.297-.297-.297h-.297z"
