---
const domains = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>`,
    title: "Architecture de Solutions",
    subtitle: "Des fondations solides pour votre croissance",
    description: "Je conçois des architectures techniques qui évoluent avec votre business. Fini les systèmes rigides qui freinent votre développement : je crée des solutions modulaires, maintenables et performantes.",
    valueProps: [
      "Réduction des coûts d'infrastructure jusqu'à 40%",
      "Systèmes capables de supporter x10 de charge",
      "Documentation claire pour vos équipes"
    ],
    techDetails: "Microservices, API-first, event-driven architecture, design patterns éprouvés"
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
    title: "Intelligence Artificielle & GenAI",
    subtitle: "L'IA au service de votre productivité",
    description: "J'intègre l'intelligence artificielle là où elle crée vraiment de la valeur. Pas de gadgets : des solutions concrètes qui automatisent vos tâches répétitives, enrichissent vos données et augmentent vos équipes.",
    valueProps: [
      "Automatisation de processus manuels chronophages",
      "Assistants IA personnalisés pour vos métiers",
      "Exploitation intelligente de vos données internes"
    ],
    techDetails: "LLM (GPT-4, Claude, Mistral), RAG, agents autonomes, fine-tuning, vector databases"
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>`,
    title: "Cloud & DevOps",
    subtitle: "Déployez plus vite, dormez sur vos deux oreilles",
    description: "Je modernise vos infrastructures pour les rendre plus fiables, plus économiques et plus agiles. Vos équipes livrent plus vite, vos systèmes tiennent la charge, et vous gardez le contrôle sur vos coûts.",
    valueProps: [
      "Déploiements automatisés plusieurs fois par jour",
      "Haute disponibilité (99.9%+) sans surcoût",
      "Facture cloud optimisée et prévisible"
    ],
    techDetails: "AWS, Azure, GCP, Terraform, Kubernetes, CI/CD, monitoring, Infrastructure as Code"
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
    title: "Développement Web",
    subtitle: "Des applications qui convertissent",
    description: "Je développe des applications web rapides, accessibles et optimisées pour le référencement. Que ce soit un site vitrine, une plateforme métier ou un e-commerce, je privilégie la performance et l'expérience utilisateur.",
    valueProps: [
      "Score Lighthouse 95+ (SEO, performance, accessibilité)",
      "Temps de chargement < 2 secondes",
      "Interfaces intuitives qui réduisent le support"
    ],
    techDetails: "React, Next.js, Vue.js, Node.js, TypeScript, PHP/Symfony, headless CMS"
  }
];

const technologies = {
  "IA & Machine Learning": [
    "OpenAI API", "Claude API", "LangChain", "LlamaIndex",
    "Hugging Face", "RAG", "Vector DBs", "Prompt Engineering"
  ],
  "Cloud Platforms": [
    "AWS (Certified)", "Azure", "GCP", "Terraform",
    "Kubernetes", "Docker", "Serverless"
  ],
  "Backend": [
    "Node.js", "TypeScript", "Python", "PHP", "Symfony",
    "NestJS", "FastAPI", "GraphQL", "REST"
  ],
  "Frontend": [
    "React", "Next.js", "Vue.js", "Astro", "Tailwind CSS"
  ],
  "Data": [
    "PostgreSQL", "MongoDB", "Redis", "Elasticsearch", "Pinecone", "Weaviate"
  ],
  "DevOps & Tools": [
    "GitHub Actions", "GitLab CI", "Jenkins", "ArgoCD", "Datadog"
  ]
};
---

<section id="expertise" class="section section-alt">
  <div class="container">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="fade-in text-3xl font-bold text-[var(--color-text-primary)] mb-4">
        Expertise
      </h2>
      <p class="fade-in stagger-1 text-[var(--color-text-secondary)] max-w-2xl mx-auto text-lg">
        17+ années à transformer des défis techniques en avantages compétitifs
      </p>
    </div>

    <!-- Domains Grid -->
    <div class="grid lg:grid-cols-2 gap-8 mb-20">
      {domains.map((domain, index) => (
        <article class={`fade-in stagger-${index + 1} p-8 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-primary)]/50 hover:border-[var(--color-border-hover)] transition-all group`}>
          <!-- Header -->
          <div class="flex items-start gap-4 mb-5">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-[var(--color-accent-primary)]/30 to-[var(--color-accent-secondary)]/30 flex items-center justify-center text-[var(--color-accent-primary)] group-hover:from-[var(--color-accent-primary)]/40 group-hover:to-[var(--color-accent-secondary)]/40 transition-all">
              <Fragment set:html={domain.icon} />
            </div>
            <div>
              <h3 class="text-xl font-semibold text-[var(--color-text-primary)]">
                {domain.title}
              </h3>
              <p class="text-sm text-[var(--color-accent-primary)]">
                {domain.subtitle}
              </p>
            </div>
          </div>

          <!-- Description -->
          <p class="text-[var(--color-text-secondary)] mb-6 leading-relaxed">
            {domain.description}
          </p>

          <!-- Value Props -->
          <ul class="space-y-2 mb-6">
            {domain.valueProps.map(prop => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="text-[var(--color-text-primary)]">{prop}</span>
              </li>
            ))}
          </ul>

          <!-- Tech Details -->
          <div class="pt-4 border-t border-[var(--color-border)]">
            <p class="text-xs text-[var(--color-text-muted)]">
              <span class="font-medium">Stack technique :</span> {domain.techDetails}
            </p>
          </div>
        </article>
      ))}
    </div>

    <!-- Technologies -->
    <div class="fade-in">
      <h3 class="text-xl font-semibold text-[var(--color-text-primary)] mb-2 text-center">
        Technologies maîtrisées
      </h3>
      <p class="text-[var(--color-text-muted)] text-center mb-10 max-w-xl mx-auto">
        Un écosystème technique large pour choisir les bons outils selon vos besoins, pas l'inverse.
      </p>
      <div class="space-y-6 max-w-4xl mx-auto">
        {Object.entries(technologies).map(([category, techs]) => (
          <div>
            <h4 class="text-sm font-medium text-[var(--color-text-muted)] mb-3 uppercase tracking-wider">
              {category}
            </h4>
            <div class="flex flex-wrap gap-2">
              {techs.map(tech => (
                <span class="tech-badge">{tech}</span>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-12 text-center">
        <a href="#contact" class="btn btn-primary">
          Parlons de votre stack technique
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
