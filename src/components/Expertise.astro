---

<section id="expertise" class="section section-alt">
  <div class="container">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="fade-in text-3xl font-bold text-[var(--color-text-primary)] mb-4">
        Expertise
      </h2>
      <p class="fade-in stagger-1 text-[var(--color-text-secondary)] max-w-2xl mx-auto text-lg">
        17+ années à transformer des défis techniques en avantages compétitifs
      </p>
    </div>

    <!-- Domains Grid -->
    <div class="grid lg:grid-cols-2 gap-8 mb-20">
      {domains.map((domain, index) => (
        <article class={`fade-in stagger-${index + 1} p-8 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-primary)]/50 hover:border-[var(--color-border-hover)] transition-all group`}>
          <!-- Header -->
          <div class="flex items-start gap-4 mb-5">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-[var(--color-accent-primary)]/30 to-[var(--color-accent-secondary)]/30 flex items-center justify-center text-[var(--color-accent-primary)] group-hover:from-[var(--color-accent-primary)]/40 group-hover:to-[var(--color-accent-secondary)]/40 transition-all">
              <Fragment set:html={domain.icon} />
            </div>
            <div>
              <h3 class="text-xl font-semibold text-[var(--color-text-primary)]">
                {domain.title}
              </h3>
              <p class="text-sm text-[var(--color-accent-primary)]">
                {domain.subtitle}
              </p>
            </div>
          </div>

          <!-- Description -->
          <p class="text-[var(--color-text-secondary)] mb-6 leading-relaxed">
            {domain.description}
          </p>

          <!-- Value Props -->
          <ul class="space-y-2 mb-6">
            {domain.valueProps.map(prop => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="text-[var(--color-text-primary)]">{prop}</span>
              </li>
            ))}
          </ul>

          <!-- Tech Details -->
          <div class="pt-4 border-t border-[var(--color-border)]">
            <p class="text-xs text-[var(--color-text-muted)]">
              <span class="font-medium">Stack technique :</span> {domain.techDetails}
            </p>
          </div>
        </article>
      ))}
    </div>

    <!-- Technologies -->
    <div class="fade-in">
      <h3 class="text-xl font-semibold text-[var(--color-text-primary)] mb-2 text-center">
        Technologies maîtrisées
      </h3>
      <p class="text-[var(--color-text-muted)] text-center mb-10 max-w-xl mx-auto">
        Un écosystème technique large pour choisir les bons outils selon vos besoins, pas l'inverse.
      </p>
      <div class="space-y-8 max-w-5xl mx-auto">
        {technologies.map((category) => (
          <div>
            <h4 class="text-sm font-medium text-[var(--color-text-muted)] mb-4 uppercase tracking-wider">
              {category.title}
            </h4>
            <div class="flex flex-wrap gap-2">
              {category.techs.map(tech => (
                <span class="tech-badge-icon" style={`--tech-color: ${tech.color};`}>
                  <span class="tech-icon" style={`color: ${tech.color};`} set:html={tech.icon} />
                  <span>{tech.name}</span>
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-12 text-center">
        <a href="#contact" class="btn btn-primary">
          Parlons de votre stack technique
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

