---
import type { Partner } from '../../data/partners';
import PartnerBadge from './PartnerBadge.astro';

interface Props {
  partner: Partner;
  index?: number;
}

const { partner, index = 0 } = Astro.props;
---

<div
  class="partner-card-container"
  style={`--delay: ${index * 100}ms; --accent-color: ${partner.color};`}
>
  <div class="partner-card" id={`partner-${partner.id}`}>
    <!-- Front of card -->
    <div class="card-face card-front">
      <div class="avatar-container">
        <img
          src={partner.avatar}
          alt={partner.name}
          width="200"
          height="200"
          class="avatar"
          loading="lazy"
        />
        <div class="avatar-ring"></div>
      </div>
      <h3 class="name">{partner.name}</h3>
      <p class="title">{partner.title}</p>
      {partner.company && <p class="company">@ {partner.company}</p>}
      <div class="skills">
        {partner.skills.slice(0, 3).map((skill) => <span class="skill-tag">{skill}</span>)}
      </div>
      <div class="flip-hint">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
          ></path>
        </svg>
        <span>Cliquez pour en savoir plus</span>
      </div>
    </div>

    <!-- Back of card -->
    <div class="card-face card-back">
      <p class="description">{partner.description}</p>

      <div class="badges">
        {partner.badges.map((badge) => <PartnerBadge badge={badge} />)}
      </div>

      <div class="links">
        {
          partner.links.linkedin && (
            <a
              href={partner.links.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="link-btn"
              aria-label="LinkedIn"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
            </a>
          )
        }
        {
          partner.links.github && (
            <a
              href={partner.links.github}
              target="_blank"
              rel="noopener noreferrer"
              class="link-btn"
              aria-label="GitHub"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
            </a>
          )
        }
        {
          partner.links.website && (
            <a
              href={partner.links.website}
              target="_blank"
              rel="noopener noreferrer"
              class="link-btn"
              aria-label="Website"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
                />
              </svg>
            </a>
          )
        }
      </div>
    </div>
  </div>
</div>

<style>
  .partner-card-container {
    perspective: 1000px;
    animation: card-appear 0.5s ease-out forwards;
    animation-delay: var(--delay);
    opacity: 0;
    transform: translateY(20px);
    cursor: pointer;
  }

  @keyframes card-appear {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .partner-card {
    position: relative;
    width: 100%;
    height: 380px;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .partner-card.flipped {
    transform: rotateY(180deg);
  }

  .card-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    border-radius: 1rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.2);
  }

  .card-front {
    justify-content: center;
  }

  .card-back {
    transform: rotateY(180deg);
    justify-content: space-between;
    text-align: center;
  }

  .avatar-container {
    position: relative;
    margin-bottom: 1rem;
  }

  .avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--accent-color);
  }

  .avatar-ring {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 2px dashed var(--accent-color);
    opacity: 0.5;
    animation: spin 20s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 0.25rem;
  }

  .title {
    font-size: 0.875rem;
    color: var(--accent-color);
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  .company {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .skill-tag {
    font-size: 0.7rem;
    padding: 0.25rem 0.75rem;
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    color: var(--color-text-secondary);
    transition: all 0.2s;
  }

  .flip-hint {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    opacity: 0.6;
    margin-top: auto;
    transition: opacity 0.2s;
  }

  .partner-card.flipped .flip-hint {
    opacity: 0;
  }

  .description {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .links {
    display: flex;
    gap: 0.75rem;
    margin-top: auto;
  }

  .link-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-bg-tertiary);
    color: var(--color-text-secondary);
    transition: all 0.2s;
    border: 1px solid var(--color-border);
  }

  .link-btn:hover {
    background: var(--accent-color);
    color: white;
    transform: scale(1.1);
    border-color: var(--accent-color);
  }

  /* Mobile: shorter hint text */
  @media (max-width: 768px) {
    .flip-hint span {
      display: none;
    }

    .flip-hint::after {
      content: 'Tap pour voir plus';
    }
  }
</style>

<script>
  // Handle click to flip on all devices
  function initPartnerCards() {
    document.querySelectorAll('.partner-card-container').forEach((container) => {
      container.addEventListener('click', (e) => {
        // Don't flip if clicking on a link (LinkedIn, GitHub, etc.)
        if ((e.target as HTMLElement).closest('a')) return;

        const card = container.querySelector('.partner-card') as HTMLElement;
        if (card) {
          const isFlipped = card.classList.contains('flipped');
          card.classList.toggle('flipped', !isFlipped);
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initPartnerCards);
</script>
