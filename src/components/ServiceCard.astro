---
interface Props {
  icon: string;
  title: string;
  description: string;
  features: string[];
  index: number;
  size?: 'small' | 'medium' | 'large';
  href?: string;
}

const { icon, title, description, features, index, size = 'small', href } = Astro.props;
const Tag = href ? 'a' : 'article';
const anchorAttrs = href ? { href, 'aria-label': `${title} — voir le service` } : {};

// Size-based styling
const sizeClasses = {
  large: {
    icon: 'w-14 h-14',
    iconSvg: 'w-7 h-7',
    title: 'text-xl lg:text-2xl',
    description: 'text-base',
    features: 'text-sm',
  },
  medium: {
    icon: 'w-12 h-12',
    iconSvg: 'w-6 h-6',
    title: 'text-lg lg:text-xl',
    description: 'text-sm',
    features: 'text-sm',
  },
  small: {
    icon: 'w-10 h-10',
    iconSvg: 'w-5 h-5',
    title: 'text-base lg:text-lg',
    description: 'text-sm',
    features: 'text-xs',
  },
};

const styles = sizeClasses[size];
---

<Tag
  {...anchorAttrs}
  class={`card card-tilt fade-in stagger-${index + 1} group h-full flex flex-col ${href ? 'cursor-pointer hover:border-[var(--color-accent-primary)] transition-colors' : ''}`}
>
  <div class={`flex ${size === 'large' ? 'flex-col gap-4' : 'items-start gap-4'}`}>
    <div
      class={`flex-shrink-0 ${styles.icon} rounded-lg bg-gradient-to-br from-[var(--color-accent-primary)]/30 to-[var(--color-accent-secondary)]/30 flex items-center justify-center text-[var(--color-accent-primary)] group-hover:from-[var(--color-accent-primary)]/40 group-hover:to-[var(--color-accent-secondary)]/40 transition-all`}
    >
      <div class={styles.iconSvg}>
        <Fragment set:html={icon} />
      </div>
    </div>
    <div class="flex-1 flex flex-col">
      <h3 class={`${styles.title} font-semibold text-[var(--color-text-primary)] mb-2`}>
        {title}
      </h3>
      <p class={`text-[var(--color-text-secondary)] ${styles.description} mb-4 leading-relaxed`}>
        {description}
      </p>
      <ul
        class={`space-y-2 mt-auto ${size === 'large' ? 'grid grid-cols-1 lg:grid-cols-2 gap-x-4' : ''}`}
      >
        {
          features.map((feature) => (
            <li class={`flex items-center gap-2 ${styles.features} text-[var(--color-text-muted)]`}>
              <svg
                class="w-4 h-4 text-[var(--color-accent-primary)] flex-shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"
                />
              </svg>
              {feature}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
  {
    href && (
      <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-[var(--color-accent-primary)] group-hover:underline">
        Voir le service
        <svg
          class="w-4 h-4 transition-transform group-hover:translate-x-1"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    )
  }
</Tag>
