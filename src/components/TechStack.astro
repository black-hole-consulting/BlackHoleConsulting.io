---

<div class="tech-stack-card">
  <div class="tech-stack-header">
    <svg
      class="w-6 h-6 text-[var(--color-accent-primary)]"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
      ></path>
    </svg>
    <span class="gradient-text text-xl font-bold">Stack</span>
  </div>

  <div class="tech-stack-divider"></div>

  <div class="tech-stack-grid">
    {
      technologies.map((tech, index) => (
        <div
          class={`tech-badge-item fade-in stagger-${(index % 4) + 1}`}
          style={`--tech-color: ${tech.color};`}
        >
          <span class="tech-icon" style={`color: ${tech.color};`} set:html={tech.icon} />
          <span class="tech-name">{tech.name.toUpperCase()}</span>
        </div>
      ))
    }
  </div>
</div>

<style>
  .tech-stack-card {
    background: linear-gradient(
      135deg,
      var(--color-bg-secondary) 0%,
      var(--color-bg-tertiary) 100%
    );
    border: 1px solid var(--color-border);
    border-radius: 1.5rem;
    padding: 2rem;
    max-width: 32rem;
  }

  .tech-stack-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .tech-stack-divider {
    height: 1px;
    background: linear-gradient(90deg, var(--color-accent-primary), transparent);
    margin-bottom: 1.5rem;
  }

  .tech-stack-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .tech-badge-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    transition: all 0.3s ease;
    cursor: default;
  }

  .tech-badge-item:hover {
    border-color: var(--tech-color);
    box-shadow: 0 0 20px color-mix(in srgb, var(--tech-color) 20%, transparent);
    transform: translateY(-2px);
  }

  .tech-icon {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tech-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .tech-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: 0.025em;
  }

  @media (max-width: 480px) {
    .tech-stack-card {
      padding: 1.5rem;
    }

    .tech-stack-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
