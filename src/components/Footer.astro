---
const currentYear = new Date().getFullYear();

const siteUrl = 'https://blackholeconsulting.io';
const shareText = 'Black Hole Consulting - Expert Solution Architecture, IA & Cloud';

const navigation = [
  { href: '/services/', label: 'Services' },
  { href: '/#expertise', label: 'Expertise' },
  { href: '/a-propos', label: 'À propos' },
  { href: '/#methode', label: 'Méthode' },
  { href: '/contact', label: 'Contact' },
];

const legal = [
  { href: '/mentions-legales', label: 'Mentions légales' },
  { href: '/politique-confidentialite', label: 'Politique de confidentialité' },
  { href: '/cgv', label: 'CGV' },
  { href: '/credits', label: 'Crédits' },
];
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
  <div class="container mx-auto px-6 py-12">
    <div class="grid md:grid-cols-4 gap-8 mb-12">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a
          href="/"
          class="flex items-center gap-2 text-[var(--color-text-primary)] font-semibold text-lg mb-4"
        >
          <svg
            class="w-8 h-8"
            viewBox="0 0 32 32"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <circle cx="16" cy="16" r="14" stroke="url(#footer-logo-gradient)" stroke-width="2"
            ></circle>
            <circle cx="16" cy="16" r="6" fill="url(#footer-logo-gradient)"></circle>
            <defs>
              <linearGradient id="footer-logo-gradient" x1="0" y1="0" x2="32" y2="32">
                <stop offset="0%" stop-color="var(--color-accent-primary)"></stop>
                <stop offset="100%" stop-color="var(--color-accent-secondary)"></stop>
              </linearGradient>
            </defs>
          </svg>
          Black Hole Consulting
        </a>
        <p class="text-[var(--color-text-secondary)] text-sm mb-4 max-w-sm">
          Solution Architect Cloud & IA chez Sanofi. J'accompagne les entreprises dans leur
          transformation digitale avec 17 ans d'expertise technique.
        </p>
        <!-- Social -->
        <div class="flex gap-4">
          <a
            href="https://www.linkedin.com/in/cedric-jacqueline-tech"
            target="_blank"
            rel="noopener noreferrer"
            class="w-11 h-11 rounded-lg bg-[var(--color-bg-primary)] border border-[var(--color-border)] flex items-center justify-center text-[var(--color-text-secondary)] hover:text-[var(--color-accent-primary)] hover:border-[var(--color-accent-primary)] transition-colors"
            aria-label="LinkedIn"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </a>
          <a
            href="https://github.com/cedric-blackhole"
            target="_blank"
            rel="noopener noreferrer"
            class="w-11 h-11 rounded-lg bg-[var(--color-bg-primary)] border border-[var(--color-border)] flex items-center justify-center text-[var(--color-text-secondary)] hover:text-[var(--color-accent-primary)] hover:border-[var(--color-accent-primary)] transition-colors"
            aria-label="GitHub"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
          </a>
          <a
            href="/rss.xml"
            class="w-11 h-11 rounded-lg bg-[var(--color-bg-primary)] border border-[var(--color-border)] flex items-center justify-center text-[var(--color-text-secondary)] hover:text-[var(--color-accent-primary)] hover:border-[var(--color-accent-primary)] transition-colors"
            title="Flux RSS"
            aria-label="S'abonner au flux RSS"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M6.18 15.64a2.18 2.18 0 1 1 0 4.36 2.18 2.18 0 0 1 0-4.36m12.64 4.36A14.83 14.83 0 0 0 4 5.18V8a11.94 11.94 0 0 1 12 12h2.82M12 20a8 8 0 0 0-8-8v2.83A5.18 5.18 0 0 1 9.18 20H12z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-[var(--color-text-primary)] font-semibold mb-4">Navigation</h3>
        <ul class="space-y-2">
          {
            navigation.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors text-sm"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-[var(--color-text-primary)] font-semibold mb-4">Légal</h3>
        <ul class="space-y-2">
          {
            legal.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors text-sm"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Share Section -->
    <div class="mb-12 pt-8 border-t border-[var(--color-border)]">
      <h3 class="text-[var(--color-text-primary)] font-semibold mb-4 text-center">Partager</h3>
      <div class="flex justify-center gap-4">
        <!-- LinkedIn Share -->
        <a
          href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(siteUrl)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="share-button group relative"
          aria-label="Partager sur LinkedIn"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
          <span class="share-tooltip">Partager sur LinkedIn</span>
        </a>

        <!-- Twitter/X Share -->
        <a
          href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(siteUrl)}&text=${encodeURIComponent(shareText)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="share-button group relative"
          aria-label="Partager sur X (Twitter)"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
            ></path>
          </svg>
          <span class="share-tooltip">Partager sur X</span>
        </a>

        <!-- Copy Link -->
        <button
          type="button"
          class="share-button group relative"
          aria-label="Copier le lien"
          data-copy-url={siteUrl}
          id="footer-copy-link-btn"
        >
          <svg
            class="w-5 h-5 copy-icon"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
            ></path>
          </svg>
          <svg
            class="w-5 h-5 check-icon hidden"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"
            ></path>
          </svg>
          <span class="share-tooltip" id="copy-tooltip">Copier le lien</span>
        </button>
      </div>
    </div>

    <!-- Bottom -->
    <div
      class="pt-8 border-t border-[var(--color-border)] flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-[var(--color-text-muted)]"
    >
      <p>
        © {currentYear} Black Hole Consulting. Tous droits réservés.
      </p>
      <p>SIRET: 833 909 864 00021</p>
    </div>
  </div>
</footer>

<style>
  .share-button {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.5rem;
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 300ms var(--ease-out-expo);
  }

  .share-button:hover {
    color: var(--color-accent-primary);
    border-color: var(--color-accent-primary);
    transform: scale(1.1);
  }

  .share-button:active {
    transform: scale(0.95);
  }

  .share-tooltip {
    position: absolute;
    bottom: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    padding: 0.375rem 0.75rem;
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition: all 200ms var(--ease-out-expo);
    pointer-events: none;
    z-index: 10;
  }

  .share-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: var(--color-border);
  }

  .share-button:hover .share-tooltip,
  .share-button:focus .share-tooltip {
    opacity: 1;
    visibility: visible;
  }

  .share-button:focus {
    outline: none;
    box-shadow:
      0 0 0 2px var(--color-bg-primary),
      0 0 0 4px var(--color-accent-primary);
  }

  .hidden {
    display: none;
  }
</style>

<script>
  function initFooterCopyLink() {
    const copyButton = document.getElementById('footer-copy-link-btn');
    const copyIcon = copyButton?.querySelector('.copy-icon');
    const checkIcon = copyButton?.querySelector('.check-icon');
    const tooltip = document.getElementById('copy-tooltip');

    copyButton?.addEventListener('click', async () => {
      const url = copyButton.getAttribute('data-copy-url');
      if (!url) return;

      try {
        await navigator.clipboard.writeText(url);

        // Show success state
        copyIcon?.classList.add('hidden');
        checkIcon?.classList.remove('hidden');
        if (tooltip) tooltip.textContent = 'Lien copié !';

        // Reset after 2 seconds
        setTimeout(() => {
          copyIcon?.classList.remove('hidden');
          checkIcon?.classList.add('hidden');
          if (tooltip) tooltip.textContent = 'Copier le lien';
        }, 2000);
      } catch (err) {
        console.error('Failed to copy:', err);
      }
    });
  }

  document.addEventListener('astro:page-load', initFooterCopyLink);
</script>
