---
const testimonials = [
  {
    quote: "Cédric a repensé notre architecture monolithique vers des microservices sur AWS. Résultat : temps de réponse API divisé par 3, coûts d'infrastructure réduits de 47%, et une équipe dev autonome sur les déploiements. En 4 mois, nous avons rattrapé 2 ans de dette technique.",
    author: "Mathieu Dupont",
    role: "CTO",
    company: "FinSecure",
    sector: "Services Financiers",
    avatar: "https://api.dicebear.com/7.x/personas/svg?seed=Mathieu&backgroundColor=6366f1",
    linkedin: "#"
  },
  {
    quote: "Notre pipeline CI/CD était un cauchemar : 45 minutes de build, déploiements manuels le weekend. Black Hole Consulting a mis en place une architecture GitOps avec Kubernetes. Aujourd'hui, nous déployons 12 fois par jour avec zéro downtime. Le ROI a été atteint en 3 mois.",
    author: "Sophie Laurent",
    role: "VP Engineering",
    company: "ShopNova",
    sector: "E-commerce B2C",
    avatar: "https://api.dicebear.com/7.x/personas/svg?seed=Sophie&backgroundColor=8b5cf6",
    linkedin: "#"
  },
  {
    quote: "L'intégration de GPT-4 dans notre CRM semblait complexe. Cédric a conçu une solution RAG sur mesure qui analyse 50 000 tickets/mois et suggère des réponses contextuelles. Nos agents gagnent 35% de temps, et le NPS client a bondi de 42 à 67 en 6 mois.",
    author: "Alexandre Martin",
    role: "Directeur Innovation",
    company: "AssurTech Pro",
    sector: "Assurance",
    avatar: "https://api.dicebear.com/7.x/personas/svg?seed=Alexandre&backgroundColor=ec4899",
    linkedin: "#"
  }
];
---

<section id="temoignages" class="section section-alt">
  <div class="container">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="fade-in text-3xl font-bold text-[var(--color-text-primary)] mb-4">
        Ce que disent mes clients
      </h2>
      <p class="fade-in stagger-1 text-[var(--color-text-secondary)] max-w-2xl mx-auto">
        Des collaborations réussies qui parlent d'elles-mêmes
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map((testimonial, index) => (
        <article class={`fade-in stagger-${index + 1} card card-tilt flex flex-col`}>
          <!-- Quote icon -->
          <svg class="w-8 h-8 text-[var(--color-accent-primary)] mb-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>

          <!-- Quote text -->
          <blockquote class="flex-1 text-[var(--color-text-secondary)] leading-relaxed mb-6">
            "{testimonial.quote}"
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-4 border-t border-[var(--color-border)]">
            <img
              src={testimonial.avatar}
              alt={`Photo de ${testimonial.author}`}
              class="w-12 h-12 rounded-full ring-2 ring-[var(--color-accent-primary)]/60"
              loading="lazy"
            />
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="text-[var(--color-text-primary)] font-medium text-sm truncate">
                  {testimonial.author}
                </span>
                <a
                  href={testimonial.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Profil LinkedIn de ${testimonial.author}`}
                  class="text-[var(--color-text-muted)] hover:text-[#0A66C2] transition-colors flex-shrink-0"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
              </div>
              <div class="text-[var(--color-text-secondary)] text-xs">
                {testimonial.role}
              </div>
              <div class="text-[var(--color-text-muted)] text-xs flex items-center gap-1 mt-0.5">
                <span class="font-medium">{testimonial.company}</span>
                <span class="text-[var(--color-border)]">|</span>
                <span>{testimonial.sector}</span>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA -->
    <div class="fade-in text-center mt-16">
      <p class="text-[var(--color-text-secondary)] mb-6">
        Rejoignez ces entreprises qui ont accéléré leur transformation digitale
      </p>
      <a href="#contact" class="btn btn-primary">
        Démarrer votre projet
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
