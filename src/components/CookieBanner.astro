---
// Cookie consent banner for GDPR compliance
---

<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-50 p-4 bg-[var(--color-bg-secondary)] border-t border-[var(--color-border)] transform translate-y-full transition-transform duration-300"
  role="dialog"
  aria-labelledby="cookie-title"
  aria-describedby="cookie-description"
>
  <div class="container mx-auto max-w-4xl">
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <div class="flex-1">
        <h2 id="cookie-title" class="text-sm font-semibold text-[var(--color-text-primary)] mb-1">
          🍪 Cookies & Confidentialité
        </h2>
        <p id="cookie-description" class="text-sm text-[var(--color-text-secondary)]">
          Nous utilisons des cookies pour analyser le trafic et améliorer votre expérience.
          <a
            href="/politique-confidentialite"
            class="text-[var(--color-accent-primary)] hover:underline"
          >
            En savoir plus
          </a>
        </p>
      </div>
      <div class="flex gap-3 w-full sm:w-auto">
        <button
          id="cookie-reject"
          class="flex-1 sm:flex-none px-4 py-2 text-sm font-medium text-[var(--color-text-secondary)] bg-[var(--color-bg-primary)] border border-[var(--color-border)] rounded-lg hover:border-[var(--color-text-muted)] transition-colors"
        >
          Refuser
        </button>
        <button
          id="cookie-accept"
          class="flex-1 sm:flex-none px-4 py-2 text-sm font-medium text-white bg-gradient-to-r from-[var(--color-accent-primary)] to-[var(--color-accent-secondary)] rounded-lg hover:opacity-90 transition-opacity"
        >
          Accepter
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var CONSENT_KEY = 'bhc_cookie_consent';

    function getConsent() {
      return localStorage.getItem(CONSENT_KEY);
    }

    function setConsent(value) {
      localStorage.setItem(CONSENT_KEY, value);
      // Update GTM consent
      if (typeof window.gtag === 'function') {
        window.gtag('consent', 'update', {
          analytics_storage: value,
          ad_storage: value,
        });
      }
    }

    function showBanner() {
      var banner = document.getElementById('cookie-banner');
      if (banner) {
        banner.classList.remove('translate-y-full');
        banner.classList.add('translate-y-0');
      }
    }

    function hideBanner() {
      var banner = document.getElementById('cookie-banner');
      if (banner) {
        banner.classList.add('translate-y-full');
        banner.classList.remove('translate-y-0');
      }
    }

    function init() {
      var consent = getConsent();

      if (!consent) {
        // No consent yet, show banner after a short delay
        setTimeout(showBanner, 1000);
      }

      // Accept button
      var acceptBtn = document.getElementById('cookie-accept');
      if (acceptBtn) {
        acceptBtn.addEventListener('click', function () {
          setConsent('granted');
          hideBanner();
        });
      }

      // Reject button
      var rejectBtn = document.getElementById('cookie-reject');
      if (rejectBtn) {
        rejectBtn.addEventListener('click', function () {
          setConsent('denied');
          hideBanner();
        });
      }
    }

    // Run on DOM ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
