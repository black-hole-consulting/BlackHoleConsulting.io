---

<div class="grid md:grid-cols-2 gap-6">
  {
    categories.map((category, categoryIndex) => (
      <div class={`fade-in stagger-${(categoryIndex % 4) + 1} skills-card`}>
        <div class="skills-header">
          <span class="text-[var(--color-accent-primary)]" set:html={category.headerIcon} />
          <span class="gradient-text text-xl font-bold">{category.title}</span>
        </div>

        <div class="skills-divider" />

        <div class="skills-grid">
          {category.technologies.map((tech, index) => (
            <div
              class={`skill-badge fade-in stagger-${(index % 4) + 1}`}
              style={`--tech-color: ${tech.color};`}
            >
              <span class="skill-icon" style={`color: ${tech.color};`} set:html={tech.icon} />
              <span class="skill-name">{tech.name.toUpperCase()}</span>
            </div>
          ))}
        </div>
      </div>
    ))
  }
</div>

<style>
  .skills-card {
    background: linear-gradient(
      135deg,
      var(--color-bg-secondary) 0%,
      var(--color-bg-tertiary) 100%
    );
    border: 1px solid var(--color-border);
    border-radius: 1.5rem;
    padding: 1.5rem;
  }

  .skills-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .skills-divider {
    height: 1px;
    background: linear-gradient(90deg, var(--color-accent-primary), transparent);
    margin-bottom: 1.25rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  .skill-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.75rem;
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    transition: all 0.3s ease;
    cursor: default;
  }

  .skill-badge:hover {
    border-color: var(--tech-color);
    box-shadow: 0 0 15px color-mix(in srgb, var(--tech-color) 20%, transparent);
    transform: translateY(-1px);
  }

  .skill-icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .skill-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .skill-name {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: 0.02em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 640px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
