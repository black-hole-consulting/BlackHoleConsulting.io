---
/**
 * CustomCursor.astro
 * A custom cursor component with a main dot and follower ring
 * - Smooth following animation
 * - Scale + glow on interactive elements
 * - Completely disabled on touch/mobile devices
 * - Respects prefers-reduced-motion accessibility preference
 */
---

<!-- Cursor elements - hidden by default, shown only on supported devices -->
<div id="cursor-dot" class="cursor-dot" aria-hidden="true"></div>
<div id="cursor-ring" class="cursor-ring" aria-hidden="true"></div>

<style>
  /*
   * Hide cursor elements by default on touch devices and reduced motion
   * Using CSS media queries as first line of defense (before JS loads)
   */
  @media (pointer: coarse), (hover: none) {
    .cursor-dot,
    .cursor-ring {
      display: none !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor-dot,
    .cursor-ring {
      display: none !important;
    }
  }

  /* Hide native cursor when custom cursor is active */
  :global(.custom-cursor-active) {
    cursor: none !important;
  }

  :global(.custom-cursor-active *) {
    cursor: none !important;
  }

  /* Main cursor dot */
  .cursor-dot {
    position: fixed;
    top: 0;
    left: 0;
    width: 8px;
    height: 8px;
    background: var(--color-text-primary, #fafafa);
    border-radius: 50%;
    pointer-events: none;
    /* z-index lower than modals (typically 1000+) but above content */
    z-index: 9990;
    opacity: 0;
    transform: translate(-50%, -50%);
    transition:
      opacity 300ms ease,
      transform 150ms ease,
      background-color 200ms ease;
    will-change: transform, opacity;
  }

  /* Follower ring */
  .cursor-ring {
    position: fixed;
    top: 0;
    left: 0;
    width: 40px;
    height: 40px;
    border: 1px solid var(--color-accent-primary, #6366f1);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9989;
    opacity: 0;
    transform: translate(-50%, -50%);
    transition:
      opacity 300ms ease,
      width 200ms ease,
      height 200ms ease,
      border-color 200ms ease,
      background-color 200ms ease;
    will-change: transform, opacity;
  }

  /* Visible state */
  .cursor-dot.visible,
  .cursor-ring.visible {
    opacity: 1;
  }

  /* Hover state on interactive elements */
  .cursor-dot.hover {
    transform: translate(-50%, -50%) scale(1.5);
    background: var(--color-accent-primary, #6366f1);
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.6);
  }

  .cursor-ring.hover {
    width: 60px;
    height: 60px;
    border-color: var(--color-accent-secondary, #8b5cf6);
    background-color: rgba(99, 102, 241, 0.1);
    box-shadow: 0 0 30px rgba(99, 102, 241, 0.3);
  }

  /* Click state */
  .cursor-dot.click {
    transform: translate(-50%, -50%) scale(0.8);
  }

  .cursor-ring.click {
    width: 30px;
    height: 30px;
  }

  /* Hidden state (JS fallback) */
  .cursor-hidden {
    display: none !important;
  }
</style>

<script>
  (function initCustomCursor() {
    /**
     * Comprehensive check for devices that should NOT have custom cursor:
     * - Touch-primary devices (phones, tablets)
     * - Devices with coarse pointer (no precise mouse)
     * - Devices without hover capability
     * - Users who prefer reduced motion
     */
    const shouldDisableCursor = (): boolean => {
      // Check CSS media queries (most reliable for device capability)
      const hasCoarsePointer = window.matchMedia('(pointer: coarse)').matches;
      const hasNoHover = window.matchMedia('(hover: none)').matches;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // If primary input is coarse (touch) or device can't hover, disable
      if (hasCoarsePointer || hasNoHover || prefersReducedMotion) {
        return true;
      }

      // Additional check: if device has touch AND no fine pointer, disable
      // This catches tablets that might report hover: hover but are primarily touch
      const hasFinePointer = window.matchMedia('(pointer: fine)').matches;
      const hasTouchCapability = 'ontouchstart' in window || navigator.maxTouchPoints > 0;

      // Only disable if touch is the PRIMARY input (no fine pointer available)
      if (hasTouchCapability && !hasFinePointer) {
        return true;
      }

      return false;
    };

    // Exit early and ensure elements are hidden
    if (shouldDisableCursor()) {
      const cursorDot = document.getElementById('cursor-dot');
      const cursorRing = document.getElementById('cursor-ring');
      if (cursorDot) cursorDot.classList.add('cursor-hidden');
      if (cursorRing) cursorRing.classList.add('cursor-hidden');
      return;
    }

    const cursorDot = document.getElementById('cursor-dot');
    const cursorRing = document.getElementById('cursor-ring');

    if (!cursorDot || !cursorRing) return;

    // Add class to body to hide native cursor
    document.body.classList.add('custom-cursor-active');

    // Mouse position
    let mouseX = 0;
    let mouseY = 0;

    // Ring position (for smooth following)
    let ringX = 0;
    let ringY = 0;

    // Animation state
    let animationFrame: number | null = null;
    let isVisible = false;
    let isAnimating = false;

    // Smooth following factor (lower = smoother, higher = more responsive)
    const followSpeed = 0.15;

    // Threshold for stopping animation (when ring is close enough to mouse)
    const stopThreshold = 0.5;

    // Track mouse position
    const onMouseMove = (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;

      // Dot follows immediately
      cursorDot.style.left = `${mouseX}px`;
      cursorDot.style.top = `${mouseY}px`;

      // Show cursors on first move
      if (!isVisible) {
        isVisible = true;
        cursorDot.classList.add('visible');
        cursorRing.classList.add('visible');
      }

      // Start animation if not already running
      if (!isAnimating) {
        startAnimation();
      }
    };

    // Animate ring following with auto-stop when stationary
    const animateRing = () => {
      // Calculate distance to target
      const dx = mouseX - ringX;
      const dy = mouseY - ringY;
      const distance = Math.sqrt(dx * dx + dy * dy);

      // Smooth interpolation
      ringX += dx * followSpeed;
      ringY += dy * followSpeed;

      cursorRing.style.left = `${ringX}px`;
      cursorRing.style.top = `${ringY}px`;

      // Continue animation only if ring hasn't caught up
      if (distance > stopThreshold) {
        animationFrame = requestAnimationFrame(animateRing);
      } else {
        isAnimating = false;
        animationFrame = null;
      }
    };

    const startAnimation = () => {
      if (!isAnimating) {
        isAnimating = true;
        animationFrame = requestAnimationFrame(animateRing);
      }
    };

    const stopAnimation = () => {
      if (animationFrame !== null) {
        cancelAnimationFrame(animationFrame);
        animationFrame = null;
      }
      isAnimating = false;
    };

    // Handle hover on interactive elements
    const interactiveSelector =
      'a, button, input, textarea, select, [role="button"], .btn, .card, .tech-badge, [data-cursor-hover]';

    const onElementMouseEnter = () => {
      cursorDot.classList.add('hover');
      cursorRing.classList.add('hover');
    };

    const onElementMouseLeave = () => {
      cursorDot.classList.remove('hover');
      cursorRing.classList.remove('hover');
    };

    // Handle click animation
    const onMouseDown = () => {
      cursorDot.classList.add('click');
      cursorRing.classList.add('click');
    };

    const onMouseUp = () => {
      cursorDot.classList.remove('click');
      cursorRing.classList.remove('click');
    };

    // Hide cursor when leaving window
    const onMouseLeaveWindow = () => {
      isVisible = false;
      cursorDot.classList.remove('visible');
      cursorRing.classList.remove('visible');
      stopAnimation();
    };

    const onMouseEnterWindow = () => {
      if (mouseX > 0 || mouseY > 0) {
        isVisible = true;
        cursorDot.classList.add('visible');
        cursorRing.classList.add('visible');
      }
    };

    // Use event delegation for interactive elements (better performance)
    const onDocumentMouseOver = (e: MouseEvent) => {
      const target = e.target as Element;
      if (target.closest(interactiveSelector)) {
        onElementMouseEnter();
      }
    };

    const onDocumentMouseOut = (e: MouseEvent) => {
      const target = e.target as Element;
      const relatedTarget = e.relatedTarget as Element | null;

      // Only remove hover if we're leaving an interactive element
      // and not entering another interactive element
      if (
        target.closest(interactiveSelector) &&
        (!relatedTarget || !relatedTarget.closest(interactiveSelector))
      ) {
        onElementMouseLeave();
      }
    };

    // Initialize event listeners
    document.addEventListener('mousemove', onMouseMove, { passive: true });
    document.addEventListener('mousedown', onMouseDown);
    document.addEventListener('mouseup', onMouseUp);
    document.addEventListener('mouseover', onDocumentMouseOver, { passive: true });
    document.addEventListener('mouseout', onDocumentMouseOut, { passive: true });
    document.documentElement.addEventListener('mouseleave', onMouseLeaveWindow);
    document.documentElement.addEventListener('mouseenter', onMouseEnterWindow);

    // Disable cursor completely
    const disableCursor = () => {
      document.body.classList.remove('custom-cursor-active');
      cursorDot.classList.add('cursor-hidden');
      cursorRing.classList.add('cursor-hidden');
      stopAnimation();
    };

    // Enable cursor
    const enableCursor = () => {
      document.body.classList.add('custom-cursor-active');
      cursorDot.classList.remove('cursor-hidden');
      cursorRing.classList.remove('cursor-hidden');
      if (isVisible) {
        startAnimation();
      }
    };

    // Listen for reduced motion preference changes
    const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    reducedMotionQuery.addEventListener('change', (e) => {
      if (e.matches) {
        disableCursor();
      } else if (!shouldDisableCursor()) {
        enableCursor();
      }
    });

    // Listen for pointer type changes (e.g., connecting/disconnecting mouse on tablet)
    const pointerQuery = window.matchMedia('(pointer: fine)');
    pointerQuery.addEventListener('change', (e) => {
      if (!e.matches) {
        disableCursor();
      } else if (!shouldDisableCursor()) {
        enableCursor();
      }
    });

    // Cleanup on page unload
    window.addEventListener('beforeunload', () => {
      stopAnimation();
    });
  })();
</script>
