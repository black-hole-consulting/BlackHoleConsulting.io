---
import ServiceCard from './ServiceCard.astro';

const services = [
  {
    icon: `<svg class="w-full h-full" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>`,
    title: 'Architecture de Solutions',
    description:
      "Conception d'architectures techniques évolutives, choix technologiques stratégiques et accompagnement à la transformation digitale.",
    features: [
      'Architecture microservices & API',
      'Design patterns & best practices',
      'Documentation technique',
    ],
    size: 'large' as const,
    gridClass: 'bento-large',
  },
  {
    icon: `<svg class="w-full h-full" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
    title: 'Intelligence Artificielle & GenAI',
    description:
      'Intégration de solutions IA génératives dans vos processus métier. LLM, RAG, agents autonomes et automatisation intelligente.',
    features: [
      'Intégration LLM (OpenAI, Claude, Mistral)',
      'Systèmes RAG & knowledge bases',
      'Agents IA & workflows automatisés',
    ],
    size: 'medium' as const,
    gridClass: 'bento-medium-top',
  },
  {
    icon: `<svg class="w-full h-full" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>`,
    title: 'Cloud & DevOps',
    description:
      'Architecture cloud-native, migration, CI/CD et optimisation des coûts sur AWS, Azure et GCP.',
    features: [
      'Multi-cloud (AWS, Azure, GCP)',
      'Infrastructure as Code (Terraform)',
      'CI/CD & GitOps',
    ],
    size: 'small' as const,
    gridClass: 'bento-small-left',
  },
  {
    icon: `<svg class="w-full h-full" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
    title: 'Développement Web',
    description:
      'Applications web modernes, sites e-commerce et solutions sur mesure avec les frameworks les plus performants.',
    features: [
      'React, Next.js, Vue.js',
      'PHP/Symfony, Node.js',
      'E-commerce (SAP Commerce, Shopify)',
    ],
    size: 'small' as const,
    gridClass: 'bento-small-right',
  },
  {
    icon: `<svg class="w-full h-full" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: 'Conseil & Accompagnement',
    description:
      "Audit technique, cadrage de projets, coordination d'équipes et accompagnement stratégique pour vos initiatives digitales.",
    features: [
      'Audit & recommandations',
      'Gestion de projet Agile',
      'Formation & montée en compétences',
    ],
    size: 'medium' as const,
    gridClass: 'bento-medium-bottom',
  },
];
---

<section id="services" class="section">
  <div class="container">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="fade-in text-3xl font-bold text-[var(--color-text-primary)] mb-4">Services</h2>
      <p class="fade-in stagger-1 text-[var(--color-text-secondary)] max-w-2xl mx-auto">
        Des solutions complètes pour accompagner votre transformation digitale
      </p>
    </div>

    <!-- Services Bento Grid -->
    <div class="bento-grid">
      {
        services.map((service, index) => (
          <div class={service.gridClass}>
            <ServiceCard
              icon={service.icon}
              title={service.title}
              description={service.description}
              features={service.features}
              index={index}
              size={service.size}
            />
          </div>
        ))
      }
    </div>

    <!-- CTA -->
    <div
      class="fade-in text-center mt-16 p-8 rounded-2xl bg-gradient-to-r from-[var(--color-accent-primary)]/20 to-[var(--color-accent-secondary)]/20 border border-[var(--color-border)]"
    >
      <p class="text-[var(--color-text-primary)] text-lg font-medium mb-2">Un projet en tête ?</p>
      <p class="text-[var(--color-text-secondary)] mb-6 max-w-md mx-auto">
        Discutons de vos besoins et voyons comment je peux vous accompagner.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#contact" class="btn btn-primary"> Demander un devis gratuit </a>
        <a
          href="https://calendly.com/cedric-blackhole"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-secondary"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
            ></path>
          </svg>
          Réserver un appel
        </a>
      </div>
    </div>
  </div>
</section>
