---

<section class="py-12 md:py-16">
  <div class="container">
    <!-- Section Header -->
    <div class="text-center mb-10">
      <p
        class="fade-in text-sm uppercase tracking-widest text-[var(--color-text-muted)] font-medium"
      >
        Ils m'ont fait confiance
      </p>
    </div>

    <!-- Sector Logos Grid -->
    <div
      class="fade-in stagger-1 flex flex-wrap justify-center items-center gap-8 md:gap-12 lg:gap-16"
    >
      {
        sectors.map((sector) => (
          <div class="sector-item group flex flex-col items-center gap-3 transition-all duration-300 cursor-default">
            <div
              class="sector-icon w-14 h-14 rounded-xl flex items-center justify-center transition-all duration-300"
              set:html={sector.icon}
            />
            <span class="text-xs font-medium text-[var(--color-text-secondary)] group-hover:text-[var(--color-text-primary)] transition-colors duration-300 whitespace-nowrap">
              {sector.name}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .sector-item {
    transform: translateY(0);
  }

  .sector-item:hover {
    transform: translateY(-4px);
  }

  .sector-icon {
    background: linear-gradient(135deg, var(--color-accent-primary), var(--color-accent-secondary));
    color: white;
    box-shadow: 0 4px 16px rgba(99, 102, 241, 0.3);
  }

  .sector-item:hover .sector-icon {
    box-shadow: 0 8px 24px rgba(99, 102, 241, 0.5);
  }
</style>
