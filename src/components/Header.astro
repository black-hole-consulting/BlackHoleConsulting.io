---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '#services', label: 'Services' },
  { href: '#expertise', label: 'Expertise' },
  { href: '#methode', label: 'Méthode' },
  { href: '#contact', label: 'Contact' },
];
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="container mx-auto px-6">
    <nav class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a
        href="/"
        class="flex items-center gap-2 text-[var(--color-text-primary)] font-semibold text-lg"
      >
        <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="16" cy="16" r="14" stroke="url(#logo-gradient)" stroke-width="2"></circle>
          <circle cx="16" cy="16" r="6" fill="url(#logo-gradient)"></circle>
          <defs>
            <linearGradient id="logo-gradient" x1="0" y1="0" x2="32" y2="32">
              <stop offset="0%" stop-color="var(--color-accent-primary)"></stop>
              <stop offset="100%" stop-color="var(--color-accent-secondary)"></stop>
            </linearGradient>
          </defs>
        </svg>
        <span class="hidden sm:inline">Black Hole Consulting</span>
      </a>

      <!-- Desktop Navigation -->
      <ul class="hidden md:flex items-center gap-8">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors text-sm font-medium"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Desktop Actions: Theme Toggle + CTA Button -->
      <div class="hidden sm:flex items-center gap-4">
        <ThemeToggle />
        <a href="#contact" class="btn btn-primary text-sm py-2.5 px-5"> Discutons </a>
      </div>

      <!-- Mobile Actions: Theme Toggle + Menu Button -->
      <div class="flex sm:hidden items-center gap-2">
        <ThemeToggle />
        <button
          id="menu-toggle"
          class="p-2 text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]"
          aria-label="Menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              id="menu-icon"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-[var(--color-bg-secondary)] border-t border-[var(--color-border)]"
  >
    <ul class="container mx-auto px-6 py-4 space-y-4">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="block text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors py-2"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="pt-2">
        <a href="#contact" class="btn btn-primary w-full"> Discutons </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const header = document.getElementById('header');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');

  // Scroll effect - add glass effect class on scroll
  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;

    if (currentScroll > 50) {
      header?.classList.add('header-scrolled');
    } else {
      header?.classList.remove('header-scrolled');
    }
  });

  // Mobile menu toggle
  menuToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    menuToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

    if (isOpen) {
      menuIcon?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    } else {
      menuIcon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    }
  });

  // Close menu on link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      menuToggle?.setAttribute('aria-expanded', 'false');
      menuIcon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    });
  });
</script>

<style>
  #header {
    --color-bg-primary: #0a0a0b;
    --color-border: #27272a;
  }

  /* Glass effect applied on scroll */
  #header.header-scrolled {
    background: rgba(10, 10, 11, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  /* Light mode glass effect */
  :global(html.light) #header.header-scrolled {
    background: rgba(255, 255, 255, 0.8);
    border-bottom-color: rgba(0, 0, 0, 0.1);
  }
</style>
