---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/#services', label: 'Services' },
  { href: '/projets', label: 'Projets' },
  { href: '/#expertise', label: 'Expertise' },
  { href: '/a-propos', label: 'A propos' },
  { href: '/partenaires', label: 'Partenaires' },
  { href: '/blog', label: 'Blog' },
  { href: '/#contact', label: 'Contact' },
];
---

<header id="header" class="sticky top-0 z-50 transition-all duration-300">
  <div class="container mx-auto px-6">
    <nav class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a
        href="/"
        class="flex items-center gap-2 text-[var(--color-text-primary)] font-semibold text-lg"
      >
        <svg
          class="w-8 h-8"
          viewBox="0 0 32 32"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <circle cx="16" cy="16" r="14" stroke="url(#logo-gradient)" stroke-width="2"></circle>
          <circle cx="16" cy="16" r="6" fill="url(#logo-gradient)"></circle>
          <defs>
            <linearGradient id="logo-gradient" x1="0" y1="0" x2="32" y2="32">
              <stop offset="0%" stop-color="var(--color-accent-primary)"></stop>
              <stop offset="100%" stop-color="var(--color-accent-secondary)"></stop>
            </linearGradient>
          </defs>
        </svg>
        <span class="hidden sm:inline">Black Hole Consulting</span>
      </a>

      <!-- Desktop Navigation -->
      <ul class="hidden md:flex items-center gap-8">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors text-sm font-medium"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Desktop Actions: Theme Toggle + CTA Button -->
      <div class="hidden md:flex items-center gap-4">
        <ThemeToggle />
        <a href="/#contact" class="btn btn-primary text-sm py-2.5 px-5"> Discutons </a>
      </div>

      <!-- Mobile Actions: Theme Toggle + Menu Button -->
      <div class="flex md:hidden items-center gap-1 relative z-50">
        <ThemeToggle />
        <button
          id="menu-toggle"
          type="button"
          class="p-3 min-w-[44px] min-h-[44px] flex items-center justify-center text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] cursor-pointer"
          aria-label="Menu"
          aria-expanded="false"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              id="menu-icon"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-[var(--color-bg-secondary)] border-t border-[var(--color-border)]"
  >
    <ul class="container mx-auto px-6 py-4 space-y-1">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="block text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-tertiary)] transition-colors py-3 px-2 -mx-2 rounded-lg min-h-[44px] flex items-center"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="pt-4">
        <a href="/#contact" class="btn btn-primary w-full min-h-[44px]"> Discutons </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Use event delegation for reliable click handling
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const menuToggle = target.closest('#menu-toggle');

    if (menuToggle) {
      e.preventDefault();
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');

      if (mobileMenu) {
        const isOpen = mobileMenu.classList.contains('hidden');
        mobileMenu.classList.toggle('hidden');
        menuToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

        if (menuIcon) {
          menuIcon.setAttribute('d', isOpen ? 'M6 18L18 6M6 6l12 12' : 'M4 6h16M4 12h16M4 18h16');
        }
      }
    }

    // Close menu on mobile link click
    const mobileMenuLink = target.closest('#mobile-menu a');
    if (mobileMenuLink) {
      const mobileMenu = document.getElementById('mobile-menu');
      const menuToggle = document.getElementById('menu-toggle');
      const menuIcon = document.getElementById('menu-icon');

      mobileMenu?.classList.add('hidden');
      menuToggle?.setAttribute('aria-expanded', 'false');
      menuIcon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    }
  });

  // Scroll effect for header
  function initHeaderScroll() {
    const header = document.getElementById('header');

    window.addEventListener(
      'scroll',
      () => {
        if (window.scrollY > 50) {
          header?.classList.add('header-scrolled');
        } else {
          header?.classList.remove('header-scrolled');
        }
      },
      { passive: true }
    );
  }

  // Close menu on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const mobileMenu = document.getElementById('mobile-menu');
      const menuToggle = document.getElementById('menu-toggle');
      const menuIcon = document.getElementById('menu-icon');

      if (mobileMenu && !mobileMenu.classList.contains('hidden')) {
        mobileMenu.classList.add('hidden');
        menuToggle?.setAttribute('aria-expanded', 'false');
        menuIcon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
      }
    }
  });

  function initActiveNav() {
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('nav a[href]');
    const currentPath = window.location.pathname;

    // Highlight page-level nav links (e.g. /blog, /projets, /a-propos)
    navLinks.forEach((link) => {
      link.classList.remove('nav-active');
      const href = link.getAttribute('href') || '';
      // Match non-anchor links against current path
      if (!href.includes('#') && href !== '/' && currentPath.startsWith(href)) {
        link.classList.add('nav-active');
      }
    });

    // On homepage, use IntersectionObserver for anchor-based sections
    if (currentPath === '/' || currentPath === '') {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const id = entry.target.getAttribute('id');
              navLinks.forEach((link) => {
                link.classList.remove('nav-active');
                const href = link.getAttribute('href') || '';
                if (href === `/#${id}` || href === `#${id}`) {
                  link.classList.add('nav-active');
                }
              });
            }
          });
        },
        {
          rootMargin: '-20% 0px -80% 0px',
          threshold: 0,
        }
      );

      sections.forEach((section) => observer.observe(section));
    }
  }

  // Initialize
  initHeaderScroll();
  initActiveNav();

  // Re-initialize after View Transitions
  document.addEventListener('astro:page-load', () => {
    initActiveNav();
  });
</script>

<style>
  #header {
    --color-bg-primary: #0a0a0b;
    --color-border: #27272a;
  }

  /* Glass effect applied on scroll */
  #header.header-scrolled {
    background: rgba(10, 10, 11, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  /* Light mode glass effect */
  :global(html.light) #header.header-scrolled {
    background: rgba(255, 255, 255, 0.8);
    border-bottom-color: rgba(0, 0, 0, 0.1);
  }

  /* Active navigation link */
  :global(.nav-active) {
    color: var(--color-accent-primary) !important;
    position: relative;
  }

  :global(.nav-active)::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-accent-primary);
    border-radius: 1px;
  }
</style>
