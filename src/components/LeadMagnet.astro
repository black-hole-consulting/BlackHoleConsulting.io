---
// Lead Magnet component - Audit Technique Gratuit
---

<section id="lead-magnet" class="section relative overflow-hidden">
  <!-- Gradient background -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-[var(--color-accent-primary)]/5 via-[var(--color-bg-secondary)] to-[var(--color-accent-secondary)]/5 -z-10"
  >
  </div>

  <div class="container">
    <div class="max-w-3xl mx-auto text-center">
      <!-- Icon -->
      <div
        class="fade-in mb-8 inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-[var(--color-accent-primary)] to-[var(--color-accent-secondary)] shadow-lg shadow-[var(--color-accent-primary)]/20"
      >
        <svg
          class="w-10 h-10 text-white"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          ></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 8h1m4 0h1"
          ></path>
        </svg>
      </div>

      <!-- Title -->
      <h2 class="fade-in stagger-1 text-3xl font-bold text-[var(--color-text-primary)] mb-4">
        Recevez votre <span class="gradient-text">audit technique gratuit</span>
      </h2>

      <!-- Subtitle -->
      <p class="fade-in stagger-2 text-lg text-[var(--color-text-secondary)] mb-8 max-w-xl mx-auto">
        J'analyse votre projet et vous envoie mes recommandations personnalisees sous 48h.
      </p>

      <!-- Form -->
      <form id="lead-magnet-form" class="fade-in stagger-3 max-w-md mx-auto">
        <div class="flex flex-col sm:flex-row gap-3">
          <input
            type="email"
            id="lead-email"
            name="email"
            required
            class="input flex-1"
            placeholder="votre@email.fr"
          />
          <button type="submit" class="btn btn-primary whitespace-nowrap">
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
            </svg>
            Recevoir l'audit
          </button>
        </div>

        <!-- Reassurance -->
        <p
          class="fade-in stagger-4 mt-4 text-sm text-[var(--color-text-muted)] flex items-center justify-center gap-2"
        >
          <svg
            class="w-4 h-4 text-green-500"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
            ></path>
          </svg>
          Gratuit, sans engagement
        </p>

        <!-- Success message -->
        <div
          id="lead-success"
          class="hidden mt-6 p-4 rounded-lg bg-green-500/10 border border-green-500/20 text-green-400"
        >
          Merci ! Je vous enverrai votre audit technique dans les prochaines 48h.
        </div>

        <!-- Error message -->
        <div
          id="lead-error"
          class="hidden mt-6 p-4 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400"
        >
          Une erreur est survenue. Veuillez reessayer ou me contacter directement.
        </div>
      </form>

      <!-- Benefits list -->
      <div class="fade-in stagger-5 mt-12 grid sm:grid-cols-3 gap-6 text-left">
        <div class="flex items-start gap-3">
          <div
            class="flex-shrink-0 w-8 h-8 rounded-lg bg-[var(--color-accent-primary)]/10 flex items-center justify-center"
          >
            <svg
              class="w-4 h-4 text-[var(--color-accent-primary)]"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-[var(--color-text-primary)]">
              Analyse personnalisee
            </p>
            <p class="text-xs text-[var(--color-text-muted)]">De votre architecture actuelle</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div
            class="flex-shrink-0 w-8 h-8 rounded-lg bg-[var(--color-accent-primary)]/10 flex items-center justify-center"
          >
            <svg
              class="w-4 h-4 text-[var(--color-accent-primary)]"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-[var(--color-text-primary)]">
              Recommandations claires
            </p>
            <p class="text-xs text-[var(--color-text-muted)]">Points d'amelioration concrets</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div
            class="flex-shrink-0 w-8 h-8 rounded-lg bg-[var(--color-accent-primary)]/10 flex items-center justify-center"
          >
            <svg
              class="w-4 h-4 text-[var(--color-accent-primary)]"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-[var(--color-text-primary)]">Reponse sous 48h</p>
            <p class="text-xs text-[var(--color-text-muted)]">Retour rapide et professionnel</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const leadForm = document.getElementById('lead-magnet-form') as HTMLFormElement;
  const leadSuccessMsg = document.getElementById('lead-success');
  const leadErrorMsg = document.getElementById('lead-error');
  const leadSubmitBtn = leadForm?.querySelector('button[type="submit"]') as HTMLButtonElement;

  // Use the same API endpoint as contact form
  const API_ENDPOINT = 'https://zm4iy4pjv8.execute-api.eu-west-3.amazonaws.com/contact';

  leadForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Disable button during submission
    if (leadSubmitBtn) {
      leadSubmitBtn.disabled = true;
      leadSubmitBtn.innerHTML = `
        <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        Envoi...
      `;
    }

    // Collect form data as JSON
    const formData = new FormData(leadForm);
    const email = formData.get('email');

    const data = {
      name: 'Lead Magnet',
      email: email,
      'project-type': 'audit',
      message: "Demande d'audit technique gratuit via le lead magnet.",
    };

    try {
      const response = await fetch(API_ENDPOINT, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        leadForm.reset();
        leadSuccessMsg?.classList.remove('hidden');
        leadErrorMsg?.classList.add('hidden');
      } else {
        throw new Error('Form submission failed');
      }
    } catch {
      leadErrorMsg?.classList.remove('hidden');
      leadSuccessMsg?.classList.add('hidden');
    } finally {
      // Re-enable button
      if (leadSubmitBtn) {
        leadSubmitBtn.disabled = false;
        leadSubmitBtn.innerHTML = `
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
          </svg>
          Recevoir l'audit
        `;
      }
    }
  });
</script>
