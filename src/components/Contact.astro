---
const projectTypes = [
  { value: '', label: 'Sélectionnez un type de projet' },
  { value: 'architecture', label: 'Architecture & Conseil' },
  { value: 'ia', label: 'IA & GenAI' },
  { value: 'cloud', label: 'Cloud & DevOps' },
  { value: 'web', label: 'Développement Web' },
  { value: 'autre', label: 'Autre' },
];

// reCAPTCHA v3 site key
const RECAPTCHA_SITE_KEY = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || '';
const isProd = import.meta.env.PROD;
---

<!-- reCAPTCHA v3 Script (only in production or if key is set) -->
<script is:inline define:vars={{ RECAPTCHA_SITE_KEY, isProd }}>
  window.RECAPTCHA_SITE_KEY = RECAPTCHA_SITE_KEY;
  window.RECAPTCHA_ENABLED =
    isProd && RECAPTCHA_SITE_KEY && RECAPTCHA_SITE_KEY !== 'YOUR_RECAPTCHA_SITE_KEY';
</script>
{
  RECAPTCHA_SITE_KEY && isProd && (
    <script
      is:inline
      src={`https://www.google.com/recaptcha/api.js?render=${RECAPTCHA_SITE_KEY}`}
    />
  )
}

<section id="contact" class="section">
  <div class="container">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="fade-in text-3xl font-bold text-[var(--color-text-primary)] mb-4">
        Parlons de votre projet
      </h2>
      <p class="fade-in stagger-1 text-[var(--color-text-secondary)] max-w-2xl mx-auto">
        Prêt à concrétiser votre vision ? Discutons-en.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 max-w-5xl mx-auto">
      <!-- Contact Form -->
      <div class="fade-in stagger-2">
        <form class="space-y-6" id="contact-form" novalidate aria-describedby="form-status">
          <div class="grid md:grid-cols-2 gap-4 md:gap-6">
            <div>
              <label
                for="name"
                class="block text-sm font-medium text-[var(--color-text-primary)] mb-2"
              >
                Nom complet <span class="text-[var(--color-accent-primary)]" aria-hidden="true"
                  >*</span
                >
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                aria-required="true"
                aria-describedby="error-name"
                autocomplete="name"
                class="input"
                placeholder="Jean Dupont"
              />
              <p id="error-name" class="hidden mt-1.5 text-xs text-red-400" role="alert"></p>
            </div>
            <div>
              <label
                for="email"
                class="block text-sm font-medium text-[var(--color-text-primary)] mb-2"
              >
                Email <span class="text-[var(--color-accent-primary)]" aria-hidden="true">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                aria-required="true"
                aria-describedby="error-email"
                autocomplete="email"
                inputmode="email"
                class="input"
                placeholder="prenom@ma-societe.com"
              />
              <p id="error-email" class="hidden mt-1.5 text-xs text-red-400" role="alert"></p>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-4 md:gap-6">
            <div>
              <label
                for="company"
                class="block text-sm font-medium text-[var(--color-text-primary)] mb-2"
              >
                Société <span class="text-[var(--color-text-muted)] font-normal">(facultatif)</span>
              </label>
              <input
                type="text"
                id="company"
                name="company"
                autocomplete="organization"
                class="input"
                placeholder="Votre entreprise"
              />
            </div>
            <div>
              <label
                for="project-type"
                class="block text-sm font-medium text-[var(--color-text-primary)] mb-2"
              >
                Type de projet
              </label>
              <select id="project-type" name="project-type" class="input cursor-pointer">
                {projectTypes.map((type) => <option value={type.value}>{type.label}</option>)}
              </select>
            </div>
          </div>

          <div>
            <label
              for="message"
              class="block text-sm font-medium text-[var(--color-text-primary)] mb-2"
            >
              Message <span class="text-[var(--color-accent-primary)]" aria-hidden="true">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              aria-required="true"
              aria-describedby="error-message"
              rows="5"
              maxlength="10000"
              class="input resize-none"
              placeholder="Décrivez votre projet, vos besoins, vos contraintes..."></textarea>
            <p id="error-message" class="hidden mt-1.5 text-xs text-red-400" role="alert"></p>
          </div>

          <button type="submit" class="btn btn-primary w-full sm:w-auto">
            Envoyer le message
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </button>

          <!-- Live status region (success / error) -->
          <div id="form-status" aria-live="polite" aria-atomic="true">
            <div
              id="form-success"
              class="hidden p-4 rounded-lg bg-green-500/10 border border-green-500/20 text-green-400"
              tabindex="-1"
            >
              Merci pour votre message ! Je vous répondrai dans les plus brefs délais.
            </div>

            <div
              id="form-error"
              class="hidden p-4 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400"
              role="alert"
              tabindex="-1"
            >
              Une erreur est survenue. Veuillez réessayer ou me contacter directement par email.
            </div>
          </div>

          <!-- reCAPTCHA attribution (required when hiding badge) -->
          <p class="text-xs text-[var(--color-text-muted)] mt-4">
            Ce site est protégé par reCAPTCHA. La
            <a
              href="https://policies.google.com/privacy"
              target="_blank"
              rel="noopener noreferrer"
              class="underline hover:text-[var(--color-text-secondary)]"
              >Politique de confidentialité</a
            > et les <a
              href="https://policies.google.com/terms"
              target="_blank"
              rel="noopener noreferrer"
              class="underline hover:text-[var(--color-text-secondary)]">Conditions d'utilisation</a
            > de Google s'appliquent.
          </p>
        </form>
      </div>

      <!-- Contact Info -->
      <div class="fade-in stagger-3 space-y-8">
        <div>
          <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-6">Coordonnées</h3>
          <ul class="space-y-4">
            <li>
              <a
                href="mailto:cedric@blkhole.fr"
                class="flex items-center gap-4 text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors group"
              >
                <span
                  class="w-10 h-10 rounded-lg bg-[var(--color-bg-secondary)] border border-[var(--color-border)] flex items-center justify-center text-[var(--color-accent-primary)] group-hover:border-[var(--color-accent-primary)] transition-colors"
                >
                  <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    ></path>
                  </svg>
                </span>
                cedric@blkhole.fr
              </a>
            </li>
            <li>
              <a
                href="tel:+33602180413"
                class="flex items-center gap-4 text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors group"
              >
                <span
                  class="w-10 h-10 rounded-lg bg-[var(--color-bg-secondary)] border border-[var(--color-border)] flex items-center justify-center text-[var(--color-accent-primary)] group-hover:border-[var(--color-accent-primary)] transition-colors"
                >
                  <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                    ></path>
                  </svg>
                </span>
                +33 6 02 18 04 13
              </a>
            </li>
            <li>
              <a
                href="https://www.linkedin.com/in/cedric-jacqueline-tech"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors group"
              >
                <span
                  class="w-10 h-10 rounded-lg bg-[var(--color-bg-secondary)] border border-[var(--color-border)] flex items-center justify-center text-[var(--color-accent-primary)] group-hover:border-[var(--color-accent-primary)] transition-colors"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                    ></path>
                  </svg>
                </span>
                LinkedIn
              </a>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-4">Localisation</h3>
          <p class="text-[var(--color-text-secondary)]">
            Basé à <strong class="text-[var(--color-text-primary)]">Tours</strong><br />
            Interventions : France entière & Remote
          </p>
        </div>

        <div
          class="p-6 rounded-xl bg-[var(--color-bg-secondary)] border border-[var(--color-border)]"
        >
          <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-3">
            Préférez un appel ?
          </h3>
          <p class="text-[var(--color-text-secondary)] text-sm mb-4">
            Réservez directement un créneau de 30 minutes pour discuter de votre projet.
          </p>
          <a
            href="https://calendly.com/cedric-blkhole/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-secondary w-full"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              ></path>
            </svg>
            Réserver un appel
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // API endpoint for contact form (AWS API Gateway + Lambda)
  const API_ENDPOINT = 'https://6deuyzfjp7.execute-api.eu-west-3.amazonaws.com/contact';

  // Get reCAPTCHA token (returns empty string if disabled/unavailable)
  async function getRecaptchaToken(): Promise<string> {
    const recaptchaEnabled =
      'RECAPTCHA_ENABLED' in window && (window as Record<string, unknown>).RECAPTCHA_ENABLED;
    const grecaptcha = (window as Record<string, unknown>).grecaptcha as
      | Record<string, Function>
      | undefined;
    const siteKey = (window as Record<string, unknown>).RECAPTCHA_SITE_KEY as string | undefined;

    if (!recaptchaEnabled || !grecaptcha) {
      console.log('reCAPTCHA disabled or not loaded (dev mode)');
      return '';
    }

    return new Promise((resolve) => {
      grecaptcha.ready(() => {
        (grecaptcha.execute(siteKey, { action: 'contact_form' }) as Promise<string>)
          .then(resolve)
          .catch((err: unknown) => {
            console.warn('reCAPTCHA error:', err);
            resolve('');
          });
      });
    });
  }

  const EMAIL_REGEX =
    /^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(?:\.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)*$/;

  type FieldId = 'name' | 'email' | 'message';

  function setFieldError(field: FieldId, msg: string | null) {
    const input = document.getElementById(field) as HTMLInputElement | HTMLTextAreaElement | null;
    const errorEl = document.getElementById(`error-${field}`);
    if (!input || !errorEl) return;
    if (msg) {
      input.setAttribute('aria-invalid', 'true');
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
    } else {
      input.removeAttribute('aria-invalid');
      errorEl.textContent = '';
      errorEl.classList.add('hidden');
    }
  }

  function validateField(field: FieldId, value: string): string | null {
    const trimmed = value.trim();
    if (field === 'name') {
      if (!trimmed) return 'Veuillez saisir votre nom.';
      if (trimmed.length > 200) return 'Nom trop long (200 caractères max).';
      return null;
    }
    if (field === 'email') {
      if (!trimmed) return 'Veuillez saisir votre email.';
      if (trimmed.length > 254) return 'Email trop long.';
      if (!EMAIL_REGEX.test(trimmed)) return "Format d'email invalide.";
      return null;
    }
    if (field === 'message') {
      if (!trimmed) return 'Veuillez décrire votre projet.';
      if (trimmed.length < 10) return 'Message trop court (10 caractères min).';
      if (trimmed.length > 10000) return 'Message trop long (10 000 caractères max).';
      return null;
    }
    return null;
  }

  function validateAll(form: HTMLFormElement): FieldId | null {
    const fields: FieldId[] = ['name', 'email', 'message'];
    let firstInvalid: FieldId | null = null;
    for (const f of fields) {
      const input = form.elements.namedItem(f) as HTMLInputElement | HTMLTextAreaElement;
      const err = validateField(f, input?.value ?? '');
      setFieldError(f, err);
      if (err && !firstInvalid) firstInvalid = f;
    }
    return firstInvalid;
  }

  // Map server-side error messages to user-friendly French
  function mapServerError(serverError: string | undefined): {
    field?: FieldId;
    message: string;
  } {
    if (!serverError) {
      return {
        message:
          'Une erreur est survenue. Veuillez réessayer ou me contacter directement par email.',
      };
    }
    const lower = serverError.toLowerCase();
    if (lower.includes('missing required')) {
      return { message: 'Merci de remplir tous les champs obligatoires.' };
    }
    if (lower.includes('invalid email')) {
      return { field: 'email', message: "Format d'email invalide." };
    }
    if (lower.includes('exceeds maximum')) {
      return { message: 'Un des champs dépasse la longueur maximale autorisée.' };
    }
    if (lower.includes('invalid project type')) {
      return { message: 'Type de projet invalide.' };
    }
    if (lower.includes('recaptcha')) {
      return {
        message:
          'La vérification anti-spam a échoué. Rechargez la page et réessayez, ou contactez-moi par email.',
      };
    }
    return {
      message: 'Une erreur est survenue. Veuillez réessayer ou me contacter directement par email.',
    };
  }

  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form) return;
    const successMsg = document.getElementById('form-success');
    const errorMsg = document.getElementById('form-error');
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;

    // Inline validation: validate on blur, clear on input
    (['name', 'email', 'message'] as FieldId[]).forEach((f) => {
      const input = form.elements.namedItem(f) as HTMLInputElement | HTMLTextAreaElement | null;
      if (!input) return;
      input.addEventListener('blur', () => {
        if (input.value) setFieldError(f, validateField(f, input.value));
      });
      input.addEventListener('input', () => {
        if (input.getAttribute('aria-invalid') === 'true') {
          setFieldError(f, validateField(f, input.value));
        }
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Hide previous status
      successMsg?.classList.add('hidden');
      errorMsg?.classList.add('hidden');

      // Client-side validation
      const firstInvalid = validateAll(form);
      if (firstInvalid) {
        const el = document.getElementById(firstInvalid) as HTMLElement | null;
        el?.focus();
        return;
      }

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.setAttribute('aria-busy', 'true');
        submitBtn.innerHTML = `
          <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <circle class="opacity-50" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Envoi en cours…
        `;
      }

      const formData = new FormData(form);
      const data: Record<string, unknown> = Object.fromEntries(formData.entries());

      try {
        const recaptchaToken = await getRecaptchaToken();
        if (recaptchaToken) data.recaptchaToken = recaptchaToken;

        const response = await fetch(API_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          form.reset();
          successMsg?.classList.remove('hidden');
          (successMsg as HTMLElement | null)?.focus();
        } else {
          let serverError: string | undefined;
          try {
            const json = await response.json();
            serverError = json?.error;
          } catch {
            // ignore parse error
          }
          const mapped = mapServerError(serverError);
          if (mapped.field) {
            setFieldError(mapped.field, mapped.message);
            const el = document.getElementById(mapped.field) as HTMLElement | null;
            el?.focus();
          } else {
            if (errorMsg) {
              errorMsg.textContent = mapped.message;
              errorMsg.classList.remove('hidden');
              (errorMsg as HTMLElement).focus();
            }
          }
        }
      } catch {
        if (errorMsg) {
          errorMsg.textContent =
            'Impossible de joindre le serveur. Vérifiez votre connexion ou contactez-moi par email.';
          errorMsg.classList.remove('hidden');
          (errorMsg as HTMLElement).focus();
        }
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.removeAttribute('aria-busy');
          submitBtn.innerHTML = `
            Envoyer le message
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          `;
        }
      }
    });
  }

  document.addEventListener('astro:page-load', initContactForm);
</script>
