---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Contact from '../components/Contact.astro';

const title =
  'Contact - Consultant Solution Architect, IA & Cloud Freelance | Black Hole Consulting';
const description =
  "Discutons de votre projet d'architecture, IA générative, Cloud AWS ou développement web. Réponse sous 24h ouvrées. Basé à Tours, intervient France entière et en remote.";
const canonical = 'https://blackholeconsulting.io/contact';

const contactPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  '@id': `${canonical}#contactpage`,
  url: canonical,
  name: 'Contact - Black Hole Consulting',
  description,
  inLanguage: 'fr-FR',
  isPartOf: {
    '@id': 'https://blackholeconsulting.io/#website',
  },
  about: {
    '@id': 'https://blackholeconsulting.io/#localbusiness',
  },
  mainEntity: {
    '@id': 'https://blackholeconsulting.io/#localbusiness',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Accueil',
      item: 'https://blackholeconsulting.io/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Contact',
      item: canonical,
    },
  ],
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Header />

  <main id="main">
    <section class="relative pt-32 pb-16 overflow-hidden">
      <div class="gradient-mesh" aria-hidden="true"></div>

      <div class="container mx-auto px-6 relative z-10">
        <nav aria-label="Fil d'ariane" class="mb-8 text-sm">
          <ol class="flex items-center gap-2 text-[var(--color-text-muted)]">
            <li>
              <a href="/" class="hover:text-[var(--color-text-primary)] transition-colors">
                Accueil
              </a>
            </li>
            <li aria-hidden="true">/</li>
            <li class="text-[var(--color-text-secondary)]" aria-current="page">Contact</li>
          </ol>
        </nav>

        <div class="max-w-3xl">
          <p
            class="fade-in inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[var(--color-accent-primary)]/10 border border-[var(--color-accent-primary)]/20 text-sm text-[var(--color-accent-primary)] font-medium mb-6"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse" aria-hidden="true"
            ></span>
            Disponible pour de nouvelles missions
          </p>
          <h1
            class="fade-in stagger-1 text-4xl md:text-5xl font-bold text-[var(--color-text-primary)] mb-6"
          >
            Discutons de votre projet
            <span class="gradient-text">tech</span>
          </h1>
          <p class="fade-in stagger-2 text-lg text-[var(--color-text-secondary)] mb-8">
            Architecture, IA générative, Cloud AWS, développement web : décrivez votre besoin en
            quelques lignes, je reviens vers vous sous <strong
              class="text-[var(--color-text-primary)]">24 h ouvrées</strong
            >. Premier échange gratuit, sans engagement.
          </p>
        </div>
      </div>
    </section>

    <Contact />
  </main>

  <Footer />
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(contactPageSchema)} is:inline />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline />
