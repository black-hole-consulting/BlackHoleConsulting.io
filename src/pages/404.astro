---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Page introuvable | Black Hole Consulting"
  description="La page que vous recherchez n'existe pas ou a été déplacée."
>
  <Header />

  <main id="main" class="pt-32 pb-20">
    <div class="container mx-auto px-6">
      <div class="max-w-2xl mx-auto text-center">
        <div class="mb-8">
          <span class="text-8xl md:text-9xl font-bold gradient-text">404</span>
        </div>

        <h1 class="text-3xl md:text-4xl font-bold text-[var(--color-text-primary)] mb-4">
          Page introuvable
        </h1>

        <p class="text-lg text-[var(--color-text-secondary)] mb-8">
          La page que vous recherchez semble avoir disparu dans un trou noir. Elle n'existe pas ou a
          été déplacée.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/" class="btn btn-primary">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
              ></path>
            </svg>
            Retour à l'accueil
          </a>
          <a href="/blog" class="btn btn-secondary"> Voir le blog </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
