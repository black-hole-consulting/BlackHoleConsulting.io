---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Get all non-draft blog posts, sorted by date (newest first)
const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Extract unique tags from all posts
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();

// Format date helper
function formatDate(date: Date): string {
  return date.toLocaleDateString('fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

// SEO
const title = 'Blog Architecture, IA Générative & Cloud | Tutoriels et Guides Techniques';
const description =
  "Articles techniques sur l'architecture logicielle, l'IA générative (LLM, RAG, GPT), AWS, Terraform et le développement moderne. Guides pratiques et retours d'expérience.";
const canonical = 'https://blackholeconsulting.io/blog';

// Structured data for blog listing
const blogListData = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Blog Black Hole Consulting',
  description: description,
  url: canonical,
  publisher: {
    '@type': 'Organization',
    name: 'Black Hole Consulting',
    logo: {
      '@type': 'ImageObject',
      url: 'https://blackholeconsulting.io/logo.svg',
    },
  },
  blogPost: posts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    url: `https://blackholeconsulting.io/blog/${post.id}`,
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(blogListData)} />

  <Header />

  <main class="pt-32 pb-20">
    <div class="container mx-auto px-6">
      <!-- Page Header -->
      <header class="max-w-3xl mx-auto text-center mb-16 fade-in">
        <h1 class="text-4xl md:text-5xl font-bold text-[var(--color-text-primary)] mb-6">
          <span class="gradient-text">Blog</span>
        </h1>
        <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto">
          Reflexions et retours d'experience sur l'architecture logicielle, le cloud, l'IA
          generative et les technologies web modernes.
        </p>
      </header>

      <!-- Tags Filter -->
      {
        allTags.length > 0 && (
          <div class="max-w-4xl mx-auto mb-12 fade-in stagger-1">
            <div class="flex flex-wrap justify-center gap-2">
              <button
                class="tag-filter-btn active px-4 py-2 rounded-full text-sm font-medium transition-all border border-[var(--color-border)] bg-[var(--color-accent-primary)] text-white"
                data-tag="all"
              >
                Tous
              </button>
              {allTags.map((tag) => (
                <button
                  class="tag-filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all border border-[var(--color-border)] bg-[var(--color-bg-tertiary)] text-[var(--color-text-secondary)] hover:border-[var(--color-accent-primary)] hover:text-[var(--color-text-primary)]"
                  data-tag={tag}
                >
                  {tag}
                </button>
              ))}
            </div>
          </div>
        )
      }

      <!-- Blog Posts Grid -->
      <div class="max-w-5xl mx-auto">
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3" id="posts-grid">
          {
            posts.map((post, index) => (
              <article
                class={`blog-card card group fade-in stagger-${(index % 6) + 1}`}
                data-tags={post.data.tags.join(',')}
              >
                <a href={`/blog/${post.id}`} class="block h-full">
                  {/* Hero Image */}
                  {post.data.heroImage && (
                    <div class="aspect-video rounded-lg overflow-hidden mb-4 bg-[var(--color-bg-tertiary)]">
                      <img
                        src={post.data.heroImage}
                        alt={post.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                      />
                    </div>
                  )}

                  {/* Tags */}
                  {post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mb-3">
                      {post.data.tags.slice(0, 2).map((tag) => (
                        <span class="text-xs px-2 py-1 rounded-full bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)]">
                          {tag}
                        </span>
                      ))}
                      {post.data.tags.length > 2 && (
                        <span class="text-xs px-2 py-1 rounded-full bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)]">
                          +{post.data.tags.length - 2}
                        </span>
                      )}
                    </div>
                  )}

                  {/* Title */}
                  <h2 class="text-lg font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent-primary)] transition-colors mb-2 line-clamp-2">
                    {post.data.title}
                  </h2>

                  {/* Description */}
                  <p class="text-sm text-[var(--color-text-secondary)] line-clamp-3 mb-4">
                    {post.data.description}
                  </p>

                  {/* Date */}
                  <div class="flex items-center gap-2 text-xs text-[var(--color-text-muted)] mt-auto">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                      />
                    </svg>
                    <time datetime={post.data.pubDate.toISOString()}>
                      {formatDate(post.data.pubDate)}
                    </time>
                  </div>
                </a>
              </article>
            ))
          }
        </div>

        <!-- Empty State -->
        {
          posts.length === 0 && (
            <div class="text-center py-16">
              <p class="text-[var(--color-text-muted)]">Aucun article pour le moment.</p>
            </div>
          )
        }
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
  }

  .blog-card a {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .blog-card.hidden {
    display: none;
  }

  .tag-filter-btn.active {
    background: var(--color-accent-primary);
    border-color: var(--color-accent-primary);
    color: white;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  function initTagFilter() {
    const filterBtns = document.querySelectorAll('.tag-filter-btn');
    const blogCards = document.querySelectorAll('.blog-card');

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const selectedTag = (btn as HTMLElement).dataset.tag;

        // Update active state
        filterBtns.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');

        // Filter cards
        blogCards.forEach((card) => {
          const cardTags = (card as HTMLElement).dataset.tags?.split(',') || [];

          if (selectedTag === 'all' || cardTags.includes(selectedTag || '')) {
            card.classList.remove('hidden');
          } else {
            card.classList.add('hidden');
          }
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initTagFilter);
</script>
