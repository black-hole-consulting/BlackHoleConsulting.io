---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { services, sortedServices } from '../../data/services';

export async function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const canonical = `https://blackholeconsulting.io/services/${service.slug}/`;

const otherServices = sortedServices.filter((s) => s.slug !== service.slug);

// Schema.org Service
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${canonical}#service`,
  name: service.title,
  alternateName: service.navLabel,
  description: service.metaDescription,
  serviceType: service.serviceType,
  url: canonical,
  provider: { '@id': 'https://blackholeconsulting.io/#localbusiness' },
  areaServed: [
    { '@type': 'Country', name: 'France' },
    { '@type': 'AdministrativeArea', name: 'Île-de-France' },
    { '@type': 'AdministrativeArea', name: 'Centre-Val de Loire' },
  ],
  audience: {
    '@type': 'BusinessAudience',
    audienceType: 'B2B',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: `Offres ${service.navLabel}`,
    itemListElement: service.offerings.map((o, i) => ({
      '@type': 'Offer',
      position: i + 1,
      itemOffered: {
        '@type': 'Service',
        name: o.name,
        description: o.description,
      },
    })),
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://blackholeconsulting.io/' },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Services',
      item: 'https://blackholeconsulting.io/services/',
    },
    { '@type': 'ListItem', position: 3, name: service.navLabel, item: canonical },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: service.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<BaseLayout title={service.metaTitle} description={service.metaDescription} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />

  <Header />

  <main id="main">
    <!-- Hero -->
    <section class="relative pt-32 pb-16 overflow-hidden">
      <div class={`pillar-hero-glow bg-gradient-to-br ${service.heroAccent}`} aria-hidden="true">
      </div>
      <div class="container mx-auto px-6 relative z-10">
        <nav aria-label="Fil d'ariane" class="mb-8 text-sm">
          <ol class="flex items-center gap-2 text-[var(--color-text-muted)]">
            <li>
              <a href="/" class="hover:text-[var(--color-text-primary)] transition-colors"
                >Accueil</a
              >
            </li>
            <li aria-hidden="true">/</li>
            <li>
              <a href="/services/" class="hover:text-[var(--color-text-primary)] transition-colors"
                >Services</a
              >
            </li>
            <li aria-hidden="true">/</li>
            <li class="text-[var(--color-text-secondary)]" aria-current="page">
              {service.navLabel}
            </li>
          </ol>
        </nav>

        <div class="max-w-3xl">
          <p
            class="fade-in inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[var(--color-accent-primary)]/10 border border-[var(--color-accent-primary)]/20 text-sm text-[var(--color-accent-primary)] font-medium mb-6"
          >
            <span class="text-base" aria-hidden="true">{service.heroIcon}</span>
            {service.heroEyebrow}
          </p>
          <h1
            class="fade-in stagger-1 text-4xl md:text-5xl font-bold text-[var(--color-text-primary)] mb-6"
          >
            {service.title}
          </h1>
          <p class="fade-in stagger-2 text-lg text-[var(--color-text-secondary)] mb-8">
            {service.heroIntro}
          </p>
          <div class="fade-in stagger-3 flex flex-col sm:flex-row gap-3">
            <a href={service.ctaPrimary.href} class="btn btn-primary">{service.ctaPrimary.label}</a>
            <a
              href={service.ctaSecondary.href}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-secondary">{service.ctaSecondary.label}</a
            >
          </div>
        </div>
      </div>
    </section>

    <!-- Pour qui / Ce que vous obtenez -->
    <section class="section py-12">
      <div class="container mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-8 max-w-5xl">
          <div class="card p-8 fade-in">
            <h2
              class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-4"
            >
              Pour qui
            </h2>
            <ul class="space-y-3">
              {
                service.whoFor.map((item) => (
                  <li class="flex items-start gap-3 text-[var(--color-text-secondary)]">
                    <svg
                      class="w-5 h-5 flex-shrink-0 mt-0.5 text-[var(--color-accent-primary)]"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                      aria-hidden="true"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"
                      />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="card p-8 fade-in stagger-1">
            <h2
              class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-4"
            >
              Ce que vous obtenez
            </h2>
            <ul class="space-y-3">
              {
                service.outcomes.map((item) => (
                  <li class="flex items-start gap-3 text-[var(--color-text-secondary)]">
                    <svg
                      class="w-5 h-5 flex-shrink-0 mt-0.5 text-[var(--color-accent-primary)]"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Offerings / Formats de mission -->
    <section class="section py-16">
      <div class="container mx-auto px-6">
        <div class="max-w-5xl">
          <h2 class="fade-in text-3xl font-bold text-[var(--color-text-primary)] mb-3">
            Formats de mission
          </h2>
          <p class="fade-in stagger-1 text-[var(--color-text-secondary)] mb-10 max-w-2xl">
            Du diagnostic court à l'accompagnement long, choisissez le format adapté à votre besoin
            et votre rythme.
          </p>
          <div class="space-y-4">
            {
              service.offerings.map((offering, i) => (
                <article class={`card p-6 md:p-8 fade-in stagger-${Math.min(i + 1, 8)}`}>
                  <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2 mb-4">
                    <h3 class="text-xl font-semibold text-[var(--color-text-primary)]">
                      {offering.name}
                    </h3>
                    {offering.duration && (
                      <span class="text-sm text-[var(--color-accent-primary)] font-medium tabular-nums">
                        {offering.duration}
                      </span>
                    )}
                  </div>
                  <p class="text-[var(--color-text-secondary)] mb-4">{offering.description}</p>
                  {offering.deliverables && (
                    <div>
                      <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-2">
                        Livrables
                      </p>
                      <ul class="space-y-1.5 text-sm text-[var(--color-text-secondary)]">
                        {offering.deliverables.map((d) => (
                          <li class="flex items-start gap-2">
                            <span
                              class="text-[var(--color-accent-primary)] mt-0.5"
                              aria-hidden="true"
                            >
                              ◦
                            </span>
                            <span>{d}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Méthode -->
    <section class="section py-16 bg-[var(--color-bg-secondary)]/40">
      <div class="container mx-auto px-6">
        <div class="max-w-5xl">
          <h2 class="fade-in text-3xl font-bold text-[var(--color-text-primary)] mb-3">
            Comment je travaille
          </h2>
          <p class="fade-in stagger-1 text-[var(--color-text-secondary)] mb-10 max-w-2xl">
            Une méthode simple, itérative, qui privilégie l'impact business à la sophistication
            technique.
          </p>
          <div class="grid md:grid-cols-2 gap-6">
            {
              service.method.map((step, i) => (
                <div class={`card p-6 fade-in stagger-${Math.min(i + 1, 8)}`}>
                  <div class="text-sm font-mono text-[var(--color-accent-primary)] mb-2">
                    {step.phase}
                  </div>
                  <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2">
                    {step.title}
                  </h3>
                  <p class="text-sm text-[var(--color-text-secondary)]">{step.description}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section py-16">
      <div class="container mx-auto px-6">
        <div class="max-w-3xl">
          <h2 class="fade-in text-3xl font-bold text-[var(--color-text-primary)] mb-3">
            Questions fréquentes
          </h2>
          <p class="fade-in stagger-1 text-[var(--color-text-secondary)] mb-10">
            Les réponses aux questions que les clients me posent le plus souvent.
          </p>
          <div class="space-y-3">
            {
              service.faqs.map((faq, i) => (
                <details class={`pillar-faq fade-in stagger-${Math.min(i + 1, 8)}`}>
                  <summary class="cursor-pointer list-none flex items-center justify-between gap-4 p-5 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-secondary)] hover:border-[var(--color-accent-primary)] transition-colors">
                    <span class="font-medium text-[var(--color-text-primary)]">{faq.question}</span>
                    <svg
                      class="pillar-faq-icon w-5 h-5 flex-shrink-0 text-[var(--color-accent-primary)] transition-transform"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 9l-7 7-7-7"
                      />
                    </svg>
                  </summary>
                  <div class="px-5 pb-5 pt-3 text-[var(--color-text-secondary)] leading-relaxed">
                    {faq.answer}
                  </div>
                </details>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- CTA bottom -->
    <section class="section py-16">
      <div class="container mx-auto px-6">
        <div
          class={`max-w-4xl mx-auto rounded-2xl p-10 md:p-12 text-center relative overflow-hidden border border-[var(--color-border)]`}
        >
          <div
            class={`absolute inset-0 bg-gradient-to-br ${service.heroAccent} opacity-10`}
            aria-hidden="true"
          >
          </div>
          <div class="relative">
            <h2 class="text-3xl font-bold text-[var(--color-text-primary)] mb-4">
              Prêt à avancer ?
            </h2>
            <p class="text-[var(--color-text-secondary)] mb-8 max-w-2xl mx-auto">
              Premier échange gratuit, sans engagement. Décrivez votre besoin par message ou
              réservez 30 minutes en visio — vous repartez avec une recommandation actionnable.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href={service.ctaPrimary.href} class="btn btn-primary"
                >{service.ctaPrimary.label}</a
              >
              <a
                href={service.ctaSecondary.href}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-secondary">{service.ctaSecondary.label}</a
              >
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Cross-sell other services -->
    <section class="section py-16 border-t border-[var(--color-border)]">
      <div class="container mx-auto px-6">
        <div class="max-w-5xl">
          <h2 class="text-2xl font-bold text-[var(--color-text-primary)] mb-8">
            Autres expertises
          </h2>
          <div class="grid md:grid-cols-3 gap-4">
            {
              otherServices.map((s) => (
                <a
                  href={`/services/${s.slug}/`}
                  class="card p-5 group hover:border-[var(--color-accent-primary)] transition-colors"
                >
                  <div class="flex items-center gap-3 mb-2">
                    <span class="text-2xl" aria-hidden="true">
                      {s.heroIcon}
                    </span>
                    <h3 class="font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent-primary)] transition-colors">
                      {s.navLabel}
                    </h3>
                  </div>
                  <p class="text-sm text-[var(--color-text-secondary)] line-clamp-2">
                    {s.heroIntro}
                  </p>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .pillar-hero-glow {
    position: absolute;
    top: -100px;
    right: -100px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.15;
    pointer-events: none;
  }
  .pillar-faq[open] .pillar-faq-icon {
    transform: rotate(180deg);
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
