---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ClientLogos from '../components/ClientLogos.astro';
import Stats from '../components/Stats.astro';
import Services from '../components/Services.astro';
import Expertise from '../components/Expertise.astro';
import LeadMagnet from '../components/LeadMagnet.astro';
import Method from '../components/Method.astro';
import FAQ from '../components/FAQ.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

// SEO optimized meta tags
const seo = {
  title: 'Consultant Solution Architect & Expert IA Générative | Black Hole Consulting',
  description:
    "Expert freelance en architecture logicielle, IA générative (LLM, RAG, GPT) et Cloud AWS. 17+ ans d'expérience. Accompagnement startups et grands comptes en France.",
  canonical: 'https://blackholeconsulting.io/',
};
---

<BaseLayout title={seo.title} description={seo.description} canonical={seo.canonical}>
  <Header />
  <main>
    <Hero />
    <ClientLogos />
    <Stats />
    <Services />
    <Expertise />
    <LeadMagnet />
    <Method />
    <FAQ />
    <Testimonials />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
