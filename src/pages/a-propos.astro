---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Timeline from '../components/Timeline.astro';
import TechStack from '../components/TechStack.astro';

const motivations = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
    title: 'Resoudre des problemes complexes',
    description:
      "J'aime les defis techniques qui demandent reflexion et creativite. Transformer un besoin flou en solution concrete, c'est ce qui me fait vibrer.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
    title: 'Faire grandir les equipes',
    description:
      "Partager mes connaissances, mentorer, voir les developpeurs progresser. Le succes d'une equipe me motive plus que les accomplissements individuels.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    title: 'Explorer les nouvelles technos',
    description:
      "L'IA generative, le cloud-native, les nouvelles architectures... Je reste curieux et j'experimente constamment pour rester a la pointe.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: 'Livrer de la valeur',
    description:
      'Pas de sur-ingenierie, pas de complexite inutile. Je me concentre sur ce qui compte : des solutions qui marchent et qui apportent de la valeur business.',
  },
];

const stackGestion = [
  { name: 'Agile / Scrum', icon: '🔄' },
  { name: 'Kanban', icon: '📋' },
  { name: 'OKR', icon: '🎯' },
  { name: 'Management 3.0', icon: '👥' },
  { name: 'Roadmap produit', icon: '🗺️' },
  { name: 'Estimation / Planning', icon: '📊' },
];

const stackCommunication = [
  { name: 'Jira / Confluence', icon: '📝' },
  { name: 'Notion', icon: '📓' },
  { name: 'Slack / Teams', icon: '💬' },
  { name: 'Miro / FigJam', icon: '🎨' },
  { name: 'Loom / Screen recording', icon: '🎥' },
  { name: 'Documentation technique', icon: '📚' },
];
---

<BaseLayout
  title="Cédric Jacqueline - Solution Architect & Expert GenAI Freelance | Black Hole Consulting"
  description="17 ans d'expérience en architecture logicielle. Ex-Sanofi, Wamiz, Meetic. Spécialiste IA générative (LLM, RAG), Cloud AWS, Terraform. Disponible en freelance France entière."
  canonical="https://blackholeconsulting.io/a-propos"
>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="relative min-h-[80vh] flex items-center overflow-hidden pt-24">
      <div class="gradient-mesh"></div>
      <div class="hero-glow"></div>

      <div class="container mx-auto px-6 py-16 relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Text content -->
          <div>
            <h1
              class="fade-in text-4xl md:text-5xl font-bold text-[var(--color-text-primary)] mb-6"
            >
              Salut, moi c'est <span class="gradient-text-animated">Cedric</span> 👋
            </h1>

            <p
              class="fade-in stagger-1 text-lg text-[var(--color-text-secondary)] mb-6 leading-relaxed"
            >
              Solution Architect chez <strong class="text-[var(--color-text-primary)]"
                >Sanofi</strong
              >, je conçois des architectures Cloud et IA depuis 17 ans.
            </p>

            <p
              class="fade-in stagger-2 text-lg text-[var(--color-text-secondary)] mb-8 leading-relaxed"
            >
              Mon parcours : developpeur PHP, Lead Dev, Head of Engineering, et maintenant
              architecte. J'ai accompagne des startups comme des grands groupes dans leur
              transformation digitale.
            </p>

            <!-- Stats inline -->
            <div class="fade-in stagger-3 flex flex-wrap gap-6 mb-8">
              <div class="flex items-center gap-2">
                <span class="text-2xl font-bold gradient-text">17+</span>
                <span class="text-sm text-[var(--color-text-muted)]">ans d'XP</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-2xl font-bold gradient-text">10+</span>
                <span class="text-sm text-[var(--color-text-muted)]">entreprises</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-2xl font-bold gradient-text">50+</span>
                <span class="text-sm text-[var(--color-text-muted)]">devs mentores</span>
              </div>
            </div>

            <!-- CTA -->
            <div class="fade-in stagger-4 flex flex-wrap gap-4">
              <a href="/#contact" class="btn btn-gradient-animated"> Me contacter </a>
              <a
                href="https://www.linkedin.com/in/cedric-jacqueline-tech"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-secondary"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                  ><path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                  ></path></svg
                >
                LinkedIn
              </a>
            </div>
          </div>

          <!-- Photo placeholder -->
          <div class="fade-in stagger-2 flex justify-center lg:justify-end">
            <div class="relative">
              <div
                class="w-48 h-48 sm:w-64 sm:h-64 md:w-80 md:h-80 rounded-full bg-gradient-to-br from-[var(--color-accent-primary)] to-[var(--color-accent-secondary)] p-1"
              >
                <div
                  class="w-full h-full rounded-full bg-[var(--color-bg-secondary)] flex items-center justify-center overflow-hidden"
                >
                  <img
                    src="/images/me/me.JPG"
                    alt="Cedric Jacqueline"
                    class="w-full h-full object-cover"
                  />
                </div>
              </div>
              <!-- Decorative elements -->
              <div
                class="absolute -top-2 -right-2 md:-top-4 md:-right-4 w-16 h-16 md:w-24 md:h-24 bg-[var(--color-accent-primary)]/20 rounded-full blur-xl"
              >
              </div>
              <div
                class="absolute -bottom-2 -left-2 md:-bottom-4 md:-left-4 w-20 h-20 md:w-32 md:h-32 bg-[var(--color-accent-secondary)]/20 rounded-full blur-xl"
              >
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Ce qui me motive -->
    <section class="section section-alt">
      <div class="container">
        <div class="text-center mb-16">
          <h2 class="fade-in text-3xl font-bold text-[var(--color-text-primary)] mb-4">
            Ce qui me motive 🔥
          </h2>
          <p class="fade-in stagger-1 text-[var(--color-text-secondary)] max-w-2xl mx-auto">
            Au-dela des technos, ce sont ces valeurs qui guident mon travail au quotidien
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          {
            motivations.map((item, index) => (
              <div class={`fade-in stagger-${(index % 4) + 1} card group`}>
                <div class="flex gap-4">
                  <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-[var(--color-accent-primary)]/20 to-[var(--color-accent-secondary)]/20 flex items-center justify-center text-[var(--color-accent-primary)] group-hover:scale-110 transition-transform">
                    <Fragment set:html={item.icon} />
                  </div>
                  <div>
                    <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2">
                      {item.title}
                    </h3>
                    <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed">
                      {item.description}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Stack Technique -->
    <section class="section">
      <div class="container">
        <div class="text-center mb-16">
          <h2 class="fade-in text-3xl font-bold text-[var(--color-text-primary)] mb-4">
            Ma stack technique 🛠️
          </h2>
          <p class="fade-in stagger-1 text-[var(--color-text-secondary)] max-w-2xl mx-auto">
            Les technologies que je maitrise et utilise au quotidien
          </p>
        </div>

        <div class="flex justify-center">
          <TechStack />
        </div>
      </div>
    </section>

    <!-- Stack Gestion & Communication -->
    <section class="section section-alt">
      <div class="container">
        <div class="grid md:grid-cols-2 gap-12 max-w-5xl mx-auto">
          <!-- Gestion de projet -->
          <div>
            <h2
              class="fade-in text-2xl font-bold text-[var(--color-text-primary)] mb-6 flex items-center gap-2"
            >
              <span>📋</span> Gestion de projet
            </h2>
            <div class="grid grid-cols-2 gap-3">
              {
                stackGestion.map((item, index) => (
                  <div
                    class={`fade-in stagger-${(index % 4) + 1} flex items-center gap-3 p-3 rounded-lg bg-[var(--color-bg-primary)] border border-[var(--color-border)]`}
                  >
                    <span class="text-xl">{item.icon}</span>
                    <span class="text-sm text-[var(--color-text-secondary)]">{item.name}</span>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- Communication -->
          <div>
            <h2
              class="fade-in text-2xl font-bold text-[var(--color-text-primary)] mb-6 flex items-center gap-2"
            >
              <span>💬</span> Communication
            </h2>
            <div class="grid grid-cols-2 gap-3">
              {
                stackCommunication.map((item, index) => (
                  <div
                    class={`fade-in stagger-${(index % 4) + 1} flex items-center gap-3 p-3 rounded-lg bg-[var(--color-bg-primary)] border border-[var(--color-border)]`}
                  >
                    <span class="text-xl">{item.icon}</span>
                    <span class="text-sm text-[var(--color-text-secondary)]">{item.name}</span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Timeline Section -->
    <section id="parcours" class="section">
      <div class="container">
        <div class="text-center mb-16">
          <h2 class="fade-in text-3xl font-bold text-[var(--color-text-primary)] mb-4">
            Mon parcours 📍
          </h2>
          <p class="fade-in stagger-1 text-[var(--color-text-secondary)] max-w-2xl mx-auto">
            17 ans d'evolution, du code a l'architecture
          </p>
        </div>

        <Timeline />
      </div>
    </section>

    <!-- Travaillons ensemble -->
    <section class="section section-alt">
      <div class="container">
        <div class="fade-in max-w-3xl mx-auto text-center">
          <h2 class="text-3xl font-bold text-[var(--color-text-primary)] mb-6">
            Travaillons ensemble 🤝
          </h2>
          <p class="text-lg text-[var(--color-text-secondary)] mb-8 leading-relaxed">
            Vous avez un projet d'architecture, une transformation cloud a mener, ou besoin d'un
            regard expert sur votre SI ? Discutons-en !
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
            <a href="/#contact" class="btn btn-gradient-animated">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
                ></path>
              </svg>
              Me contacter
            </a>
            <a
              href="https://calendly.com/cedric-blackhole"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-secondary"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                ></path>
              </svg>
              Reserver un appel
            </a>
          </div>

          <!-- Trust badges -->
          <div class="flex flex-wrap justify-center gap-6 text-sm text-[var(--color-text-muted)]">
            <div class="flex items-center gap-2">
              <svg
                class="w-5 h-5 text-green-500"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              Reponse sous 24h
            </div>
            <div class="flex items-center gap-2">
              <svg
                class="w-5 h-5 text-green-500"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              Premier echange gratuit
            </div>
            <div class="flex items-center gap-2">
              <svg
                class="w-5 h-5 text-green-500"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              Devis sous 48h
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
